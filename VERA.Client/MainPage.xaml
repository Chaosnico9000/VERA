<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:VERA.ViewModels"
             xmlns:models="clr-namespace:VERA.Models"
             x:Class="VERA.MainPage"
             x:DataType="vm:DashboardViewModel"
             BackgroundColor="{StaticResource AppBackground}"
             Title="VERA">

    <ScrollView>
        <VerticalStackLayout Spacing="0">

            <!-- Header -->
            <Grid Padding="24,48,24,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Image Grid.Column="0"
                       Source="vera_logo.png"
                       HeightRequest="52"
                       HorizontalOptions="Start"
                       Aspect="AspectFit"
                       VerticalOptions="Center" />
                <Border Grid.Column="1"
                        BackgroundColor="{StaticResource CardColor}"
                        Stroke="{StaticResource BorderColor}"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 12"
                        Padding="12,8"
                        VerticalOptions="Center">
                    <Label x:Name="DateLabel"
                           FontSize="12"
                           TextColor="{StaticResource TextSecondary}" />
                </Border>
            </Grid>

            <!-- Timer-Karte -->
            <Border Margin="16,0"
                    BackgroundColor="{StaticResource CardColor}"
                    Stroke="{StaticResource BorderColor}"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 20">
                <VerticalStackLayout Padding="24,28" Spacing="18">

                    <!-- Große Zeitanzeige -->
                    <Label Text="{Binding TimerDisplay}"
                           FontSize="60"
                           FontAttributes="Bold"
                           TextColor="{StaticResource TextPrimary}"
                           HorizontalOptions="Center"
                           FontFamily="OpenSansRegular"
                           CharacterSpacing="2" />

                    <!-- Laufender Indikator -->
                    <HorizontalStackLayout HorizontalOptions="Center"
                                           Spacing="8"
                                           IsVisible="{Binding IsRunning}">
                        <Ellipse WidthRequest="8" HeightRequest="8"
                                 Fill="{StaticResource RunningColor}"
                                 VerticalOptions="Center" />
                        <Label Text="Läuft..."
                               FontSize="13"
                               TextColor="{StaticResource RunningColor}" />
                    </HorizontalStackLayout>

                    <!-- Aufgaben-Eingabe (nur sichtbar wenn gestoppt) -->
                    <Border BackgroundColor="{StaticResource SurfaceColor}"
                            Stroke="{StaticResource BorderColor}"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 12"
                            IsVisible="{Binding IsNotRunning}">
                        <Entry Text="{Binding TaskTitle}"
                               Placeholder="Aufgabe beschreiben..."
                               PlaceholderColor="{StaticResource TextMuted}"
                               TextColor="{StaticResource TextPrimary}"
                               BackgroundColor="Transparent"
                               Margin="16,0"
                               FontSize="15"
                               ReturnType="Done" />
                    </Border>

                    <!-- Aufgabenname (sichtbar wenn läuft) -->
                    <Label Text="{Binding TaskTitle}"
                           FontSize="15"
                           TextColor="{StaticResource TextSecondary}"
                           HorizontalOptions="Center"
                           IsVisible="{Binding IsRunning}"
                           HorizontalTextAlignment="Center"
                           LineBreakMode="TailTruncation"
                           MaxLines="1" />

                    <!-- Start / Stopp -->
                    <Button Text="{Binding ButtonLabel}"
                            Command="{Binding ToggleTimerCommand}"
                            BackgroundColor="{Binding ButtonColor}"
                            TextColor="{StaticResource TextPrimary}"
                            FontSize="17"
                            FontAttributes="Bold"
                            HeightRequest="54"
                            CornerRadius="14" />

                </VerticalStackLayout>
            </Border>

            <!-- Statistik-Leiste -->
            <Grid Margin="16,14,16,6" ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        BackgroundColor="{StaticResource CardColor}"
                        Stroke="{StaticResource BorderColor}"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 16"
                        Padding="16,14">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Heute gesamt" FontSize="12" TextColor="{StaticResource TextSecondary}" />
                        <Label Text="{Binding TodayTotal}"
                               FontSize="22"
                               FontAttributes="Bold"
                               TextColor="{StaticResource SuccessColor}" />
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Column="1"
                        BackgroundColor="{StaticResource CardColor}"
                        Stroke="{StaticResource BorderColor}"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 16"
                        Padding="16,14">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Einträge heute" FontSize="12" TextColor="{StaticResource TextSecondary}" />
                        <Label Text="{Binding TodayCount}"
                               FontSize="22"
                               FontAttributes="Bold"
                               TextColor="{StaticResource Primary}" />
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <!-- Letzte Einträge -->
            <VerticalStackLayout Padding="16,8,16,24" Spacing="8">
                <Label Text="Zuletzt"
                       FontSize="18"
                       FontAttributes="Bold"
                       TextColor="{StaticResource TextPrimary}"
                       Margin="4,8,0,4" />

                <CollectionView ItemsSource="{Binding RecentEntries}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:TimeEntry">
                            <Border BackgroundColor="{StaticResource CardColor}"
                                    Stroke="{StaticResource BorderColor}"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 14"
                                    Margin="0,4"
                                    Padding="16,13">
                                <Grid ColumnDefinitions="10,*,Auto" ColumnSpacing="12">
                                    <Ellipse Grid.Column="0"
                                             WidthRequest="10" HeightRequest="10"
                                             Fill="{StaticResource Primary}"
                                             VerticalOptions="Center" />
                                    <VerticalStackLayout Grid.Column="1" Spacing="2">
                                        <Label Text="{Binding Title}"
                                               FontSize="15"
                                               FontAttributes="Bold"
                                               TextColor="{StaticResource TextPrimary}"
                                               LineBreakMode="TailTruncation" />
                                        <Label Text="{Binding StartTimeDisplay}"
                                               FontSize="12"
                                               TextColor="{StaticResource TextMuted}" />
                                    </VerticalStackLayout>
                                    <Label Grid.Column="2"
                                           Text="{Binding DurationDisplay}"
                                           FontSize="14"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource SuccessColor}"
                                           VerticalOptions="Center" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                    <CollectionView.EmptyView>
                        <Label Text="Noch keine Aufgaben – starte deinen ersten Timer!"
                               FontSize="14"
                               TextColor="{StaticResource TextMuted}"
                               HorizontalOptions="Center"
                               Margin="0,16" />
                    </CollectionView.EmptyView>
                </CollectionView>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>

