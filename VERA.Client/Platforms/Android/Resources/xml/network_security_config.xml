<?xml version="1.0" encoding="utf-8"?>
<!--
    VERA Netzwerk-Sicherheitskonfiguration
    Nur HTTPS-Verbindungen zum VERA-Backend erlaubt.
    Kein HTTP (Cleartext), keine anderen externen Hosts.
-->
<network-security-config>
    <!-- Kein Cleartext-Traffic (HTTP) – nur HTTPS -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <!-- Nur System-CAs vertrauen (kein Pinning, damit Let's Encrypt etc. funktioniert) -->
            <certificates src="system" />
        </trust-anchors>
    </base-config>
    <!-- Debug: auch User-CAs erlauben (für lokale Testserver mit selbst-signiertem Zertifikat) -->
    <debug-overrides>
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </debug-overrides>
</network-security-config>
