<?xml version="1.0" encoding="utf-8"?>
<!--
    VERA Netzwerk-Sicherheitskonfiguration
    Die Server-URL ist nutzerkonfiguriert (HTTP oder HTTPS).
    HTTPS wird empfohlen – HTTP wird toleriert damit selbst-gehostete Server ohne
    Reverse-Proxy erreichbar bleiben.
-->
<network-security-config>
    <!-- Cleartext (HTTP) erlaubt, da Server-URL vom Nutzer konfiguriert wird -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <!-- System-CAs: akzeptiert Let's Encrypt, ZeroSSL etc. -->
            <certificates src="system" />
        </trust-anchors>
    </base-config>
    <!-- Debug: zusaetzlich User-CAs erlauben (selbst-signierte Zertifikate) -->
    <debug-overrides>
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </debug-overrides>
</network-security-config>
