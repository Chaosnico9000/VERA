<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:VERA.ViewModels"
             x:Class="VERA.Views.EinstellungenPage"
             x:DataType="vm:EinstellungenViewModel"
             BackgroundColor="{DynamicResource AppBackground}"
             Title="Einstellungen">

    <ScrollView>
        <VerticalStackLayout Spacing="0">

            <!-- Header -->
            <Grid Padding="8,48,20,16" ColumnDefinitions="56,*">
                <Button Grid.Column="0" Text="&#9776;" FontSize="22"
                        TextColor="{DynamicResource TextPrimary}" BackgroundColor="Transparent"
                        Clicked="OnMenuClicked" VerticalOptions="Center" />
                <VerticalStackLayout Grid.Column="1" Spacing="1" VerticalOptions="Center">
                    <Label Text="Einstellungen" FontSize="22" FontAttributes="Bold"
                           TextColor="{DynamicResource TextPrimary}" />
                    <Label Text="Konfiguration" FontSize="11" TextColor="{DynamicResource TextMuted}" />
                </VerticalStackLayout>
            </Grid>

            <!-- Sektion: Darstellung -->
            <Label Text="DARSTELLUNG" FontSize="11" FontAttributes="Bold"
                   TextColor="{DynamicResource TextMuted}" Margin="20,24,20,8" CharacterSpacing="1.5" />

            <Border Margin="16,0" BackgroundColor="{DynamicResource CardColor}"
                    Stroke="{DynamicResource BorderColor}" StrokeThickness="1"
                    StrokeShape="RoundRectangle 16" Padding="20,18">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Theme" FontSize="16" TextColor="{DynamicResource TextPrimary}" />
                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                        <!-- Dark -->
                        <Border Grid.Column="0"
                                BackgroundColor="{Binding IsDark, Converter={StaticResource BoolToCardConverter}}"
                                Stroke="{DynamicResource BorderColor}" StrokeThickness="1"
                                StrokeShape="RoundRectangle 12" Padding="0,10">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ThemeDarkCommand}" />
                            </Border.GestureRecognizers>
                            <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                                <Label Text="&#x1F319;" FontSize="20" HorizontalOptions="Center" />
                                <Label Text="Dunkel" FontSize="12"
                                       TextColor="{DynamicResource TextPrimary}"
                                       HorizontalOptions="Center" />
                            </VerticalStackLayout>
                        </Border>
                        <!-- Light -->
                        <Border Grid.Column="1"
                                BackgroundColor="{Binding IsLight, Converter={StaticResource BoolToCardConverter}}"
                                Stroke="{DynamicResource BorderColor}" StrokeThickness="1"
                                StrokeShape="RoundRectangle 12" Padding="0,10">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ThemeLightCommand}" />
                            </Border.GestureRecognizers>
                            <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                                <Label Text="&#x2600;" FontSize="20" HorizontalOptions="Center" />
                                <Label Text="Hell" FontSize="12"
                                       TextColor="{DynamicResource TextPrimary}"
                                       HorizontalOptions="Center" />
                            </VerticalStackLayout>
                        </Border>
                        <!-- System -->
                        <Border Grid.Column="2"
                                BackgroundColor="{Binding IsSystem, Converter={StaticResource BoolToCardConverter}}"
                                Stroke="{DynamicResource BorderColor}" StrokeThickness="1"
                                StrokeShape="RoundRectangle 12" Padding="0,10">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ThemeSystemCommand}" />
                            </Border.GestureRecognizers>
                            <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                                <Label Text="&#x2699;" FontSize="20" HorizontalOptions="Center" />
                                <Label Text="System" FontSize="12"
                                       TextColor="{DynamicResource TextPrimary}"
                                       HorizontalOptions="Center" />
                            </VerticalStackLayout>
                        </Border>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Sektion: Export -->
            <Label Text="EXPORT" FontSize="11" FontAttributes="Bold"
                   TextColor="{DynamicResource TextMuted}" Margin="20,24,20,8" CharacterSpacing="1.5" />

            <Border Margin="16,0" BackgroundColor="{DynamicResource CardColor}"
                    Stroke="{DynamicResource BorderColor}" StrokeThickness="1"
                    StrokeShape="RoundRectangle 16" Padding="4">
                <Button Text="&#x1F4E4;  Tages&#xFC;bersicht teilen (WhatsApp)"
                        Command="{Binding ExportWhatsAppCommand}"
                        BackgroundColor="Transparent"
                        TextColor="{StaticResource CyanColor}"
                        FontSize="15" HeightRequest="52" />
            </Border>

            <!-- Sektion: Arbeitszeit -->
            <Label Text="ARBEITSZEIT" FontSize="11" FontAttributes="Bold"
                   TextColor="{DynamicResource TextMuted}" Margin="20,8,20,8" CharacterSpacing="1.5" />

            <Border Margin="16,0" BackgroundColor="{DynamicResource CardColor}"
                    Stroke="{DynamicResource BorderColor}" StrokeThickness="1"
                    StrokeShape="RoundRectangle 16" Padding="20,18">
                <VerticalStackLayout Spacing="16">

                    <Grid ColumnDefinitions="*,Auto">
                        <VerticalStackLayout Grid.Column="0" Spacing="3">
                            <Label Text="T&#228;gliche Sollzeit" FontSize="16" TextColor="{DynamicResource TextPrimary}" />
                            <Label Text="Deine Vertrauensarbeitszeit pro Tag" FontSize="12"
                                   TextColor="{DynamicResource TextMuted}" />
                        </VerticalStackLayout>
                        <HorizontalStackLayout Grid.Column="1" Spacing="0" VerticalOptions="Center">
                            <Button Text="&#8722;" Command="{Binding VerringernCommand}"
                                    BackgroundColor="{DynamicResource SurfaceColor}"
                                    TextColor="{DynamicResource TextPrimary}"
                                    FontSize="20" WidthRequest="42" HeightRequest="42"
                                    CornerRadius="10" Padding="0" Margin="0,0,6,0" />
                            <Border BackgroundColor="{DynamicResource SurfaceColor}"
                                    Stroke="{DynamicResource BorderColor}" StrokeThickness="1"
                                    StrokeShape="RoundRectangle 10"
                                    Padding="12,0" WidthRequest="60" HeightRequest="42">
                                <Label Text="{Binding SollzeitAnzeige}" FontSize="16" FontAttributes="Bold"
                                       TextColor="{StaticResource Primary}"
                                       HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>
                            <Button Text="+" Command="{Binding ErhoehenCommand}"
                                    BackgroundColor="{DynamicResource SurfaceColor}"
                                    TextColor="{DynamicResource TextPrimary}"
                                    FontSize="20" WidthRequest="42" HeightRequest="42"
                                    CornerRadius="10" Padding="0" Margin="6,0,0,0" />
                        </HorizontalStackLayout>
                    </Grid>

                    <BoxView HeightRequest="1" BackgroundColor="{DynamicResource BorderColor}" />

                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0" Text="Wochenziel (5 Tage)" FontSize="14"
                               TextColor="{DynamicResource TextSecondary}" VerticalOptions="Center" />
                        <Label Grid.Column="1" Text="{Binding WochenzielAnzeige}" FontSize="16"
                               FontAttributes="Bold" TextColor="{StaticResource SuccessColor}"
                               VerticalOptions="Center" />
                    </Grid>

                </VerticalStackLayout>
            </Border>

            <!-- Sektion: Arbeitsbeginn -->
            <Label Text="ARBEITSBEGINN" FontSize="11" FontAttributes="Bold"
                   TextColor="{DynamicResource TextMuted}" Margin="20,24,20,8" CharacterSpacing="1.5" />

            <Border Margin="16,0" BackgroundColor="{DynamicResource CardColor}"
                    Stroke="{DynamicResource BorderColor}" StrokeThickness="1"
                    StrokeShape="RoundRectangle 16" Padding="20,18">
                <Grid ColumnDefinitions="*,Auto">
                    <VerticalStackLayout Grid.Column="0" Spacing="3">
                        <Label Text="Erster Arbeitstag" FontSize="16" TextColor="{DynamicResource TextPrimary}" />
                        <Label Text="Ab wann die Gesamt�bersicht z�hlt" FontSize="12"
                               TextColor="{DynamicResource TextMuted}" />
                    </VerticalStackLayout>
                    <DatePicker Grid.Column="1"
                                Date="{Binding ErsterArbeitstag}"
                                Format="dd.MM.yyyy"
                                TextColor="{StaticResource Primary}"
                                BackgroundColor="Transparent"
                                FontSize="15"
                                VerticalOptions="Center" />
                </Grid>
            </Border>

            <!-- Sektion: Benachrichtigungen -->
            <Label Text="BENACHRICHTIGUNGEN" FontSize="11" FontAttributes="Bold"
                   TextColor="{DynamicResource TextMuted}" Margin="20,24,20,8" CharacterSpacing="1.5" />

            <Border Margin="16,0" BackgroundColor="{DynamicResource CardColor}"
                    Stroke="{DynamicResource BorderColor}" StrokeThickness="1"
                    StrokeShape="RoundRectangle 16" Padding="20,6">
                <VerticalStackLayout Spacing="0">

                    <!-- Toggle -->
                    <Grid ColumnDefinitions="*,Auto" Padding="0,12">
                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                            <Label Text="Erinnerung aktivieren" FontSize="16"
                                   TextColor="{DynamicResource TextPrimary}" />
                            <Label Text="Dagliche Erinnerung zum Timer starten"
                                   FontSize="12" TextColor="{DynamicResource TextMuted}" />
                        </VerticalStackLayout>
                        <Switch Grid.Column="1" IsToggled="{Binding ErinnerungAktiv}"
                                OnColor="{StaticResource Primary}"
                                ThumbColor="{DynamicResource TextPrimary}"
                                VerticalOptions="Center" />
                    </Grid>

                    <BoxView HeightRequest="1" BackgroundColor="{DynamicResource BorderColor}"
                             IsVisible="{Binding ErinnerungAktiv}" />

                    <!-- Uhrzeit -->
                    <Grid ColumnDefinitions="*,Auto" Padding="0,12"
                          IsVisible="{Binding ErinnerungAktiv}">
                        <Label Grid.Column="0" Text="Uhrzeit" FontSize="15"
                               TextColor="{DynamicResource TextSecondary}" VerticalOptions="Center" />
                        <TimePicker Grid.Column="1" Time="{Binding ErinnerungsZeit}"
                                    TextColor="{DynamicResource TextPrimary}"
                                    BackgroundColor="Transparent"
                                    Format="HH:mm" FontSize="15" />
                    </Grid>

                    <BoxView HeightRequest="1" BackgroundColor="{DynamicResource BorderColor}" />

                    <!-- Test-Button -->
                    <Button Text="&#128276; Testnachricht senden"
                            Command="{Binding TestNachrichtCommand}"
                            BackgroundColor="Transparent"
                            TextColor="{StaticResource CyanColor}"
                            FontSize="15" HeightRequest="52" />

                </VerticalStackLayout>
            </Border>

            <!-- Sektion: Account -->
            <Label Text="ACCOUNT" FontSize="11" FontAttributes="Bold"
                   TextColor="{DynamicResource TextMuted}" Margin="20,24,20,8" CharacterSpacing="1.5" />

            <Border Margin="16,0" BackgroundColor="{DynamicResource CardColor}"
                    Stroke="{DynamicResource BorderColor}" StrokeThickness="1"
                    StrokeShape="RoundRectangle 16" Padding="20,16">
                <VerticalStackLayout Spacing="12">
                    <!-- Server-URL -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="SERVER-URL"
                               FontSize="11" FontAttributes="Bold"
                               TextColor="{DynamicResource TextMuted}"
                               CharacterSpacing="1.2" />
                        <Border BackgroundColor="{DynamicResource SurfaceColor}"
                                Stroke="{DynamicResource BorderColor}" StrokeThickness="1"
                                StrokeShape="RoundRectangle 12" Padding="14,0">
                            <Entry x:Name="ServerUrlEntry"
                                   Placeholder="https://dein-server:8080"
                                   PlaceholderColor="{DynamicResource TextMuted}"
                                   TextColor="{DynamicResource TextPrimary}"
                                   FontSize="13"
                                   HeightRequest="46"
                                   BackgroundColor="Transparent"
                                   Keyboard="Url"
                                   Completed="OnServerUrlCompleted" />
                        </Border>
                        <Button Text="??  Verbindung testen"
                                Clicked="OnTestConnectionClicked"
                                BackgroundColor="{DynamicResource SurfaceColor}"
                                TextColor="{StaticResource CyanColor}"
                                FontSize="13" HeightRequest="40"
                                CornerRadius="10" Margin="0,2,0,0" />
                    </VerticalStackLayout>
                    <BoxView HeightRequest="1" BackgroundColor="{DynamicResource BorderColor}" />
                    <Button Text="??  Passwort �ndern"
                            Clicked="OnChangePasswordClicked"
                            BackgroundColor="Transparent"
                            TextColor="{DynamicResource TextPrimary}"
                            FontSize="15" HeightRequest="48" />
                </VerticalStackLayout>
            </Border>

            <!-- Sektion: Daten -->
            <Label Text="DATEN" FontSize="11" FontAttributes="Bold"
                   TextColor="{DynamicResource TextMuted}" Margin="20,24,20,8" CharacterSpacing="1.5" />

            <Border Margin="16,0" BackgroundColor="{DynamicResource CardColor}"
                    Stroke="{DynamicResource BorderColor}" StrokeThickness="1"
                    StrokeShape="RoundRectangle 16" Padding="4">
                <Button Text="&#128465;  Alle Eintr&#228;ge l&#246;schen"
                        Command="{Binding ResetCommand}"
                        BackgroundColor="Transparent"
                        TextColor="{StaticResource Accent}"
                        FontSize="15" HeightRequest="52" />
            </Border>

            <!-- Sektion: �ber die App -->
            <Label Text="�BER DIE APP" FontSize="11" FontAttributes="Bold"
                   TextColor="{DynamicResource TextMuted}" Margin="20,24,20,8" CharacterSpacing="1.5" />

            <Border Margin="16,0,16,36" BackgroundColor="{DynamicResource CardColor}"
                    Stroke="{DynamicResource BorderColor}" StrokeThickness="1"
                    StrokeShape="RoundRectangle 16" Padding="20,16">
                <VerticalStackLayout Spacing="12">

                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0" Text="Version" FontSize="15"
                               TextColor="{DynamicResource TextSecondary}" VerticalOptions="Center" />
                        <Label x:Name="VersionLabel" Grid.Column="1" FontSize="15" FontAttributes="Bold"
                               TextColor="{DynamicResource TextPrimary}" VerticalOptions="Center" />
                    </Grid>

                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0" Text="Build" FontSize="13"
                               TextColor="{DynamicResource TextMuted}" VerticalOptions="Center" />
                        <Label x:Name="BuildLabel" Grid.Column="1" FontSize="13"
                               TextColor="{DynamicResource TextMuted}" VerticalOptions="Center" />
                    </Grid>

                    <BoxView HeightRequest="1" BackgroundColor="{DynamicResource BorderColor}" />

                    <Button Text="??  Changelog anzeigen"
                            Clicked="OnChangelogClicked"
                            BackgroundColor="Transparent"
                            TextColor="{DynamicResource TextSecondary}"
                            FontSize="14" HeightRequest="40" />

                    <BoxView HeightRequest="1" BackgroundColor="{DynamicResource BorderColor}"
                             x:Name="UpdateDivider" IsVisible="False" />

                    <Button x:Name="UpdateButton"
                            IsVisible="False"
                            Clicked="OnUpdateClicked"
                            BackgroundColor="Transparent"
                            TextColor="{StaticResource CyanColor}"
                            FontSize="14" HeightRequest="40" />

                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
