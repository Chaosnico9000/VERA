<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VERA.Views.LoginPage"
             BackgroundColor="{DynamicResource AppBackground}"
             Shell.NavBarIsVisible="False"
             NavigationPage.HasNavigationBar="False">

    <Grid RowDefinitions="*,Auto,*">
        <ScrollView Grid.Row="1">
            <VerticalStackLayout HorizontalOptions="Center"
                                 MaximumWidthRequest="400"
                                 Spacing="0"
                                 Padding="32,0">

                <!-- Logo -->
                <VerticalStackLayout HorizontalOptions="Center" Spacing="8" Margin="0,0,0,36">
                    <Border BackgroundColor="{DynamicResource CardColor}"
                            Stroke="{StaticResource Primary}"
                            StrokeThickness="2"
                            StrokeShape="RoundRectangle 28"
                            WidthRequest="88" HeightRequest="88"
                            HorizontalOptions="Center">
                        <Label Text="V" FontSize="44" FontAttributes="Bold"
                               TextColor="{StaticResource Primary}"
                               HorizontalOptions="Center" VerticalOptions="Center" />
                    </Border>
                    <Label Text="VERA" FontSize="28" FontAttributes="Bold"
                           TextColor="{DynamicResource TextPrimary}"
                           HorizontalOptions="Center" CharacterSpacing="4" />
                    <Label x:Name="WelcomeLabel"
                           Text="Willkommen zurück"
                           FontSize="13" TextColor="{DynamicResource TextMuted}"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>

                <!-- Formular -->
                <VerticalStackLayout Spacing="14">

                    <!-- Server-URL -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="SERVER-URL"
                               FontSize="11" FontAttributes="Bold"
                               TextColor="{DynamicResource TextMuted}"
                               CharacterSpacing="1.2" />
                        <Border BackgroundColor="{DynamicResource CardColor}"
                                Stroke="{DynamicResource BorderColor}" StrokeThickness="1"
                                StrokeShape="RoundRectangle 14" Padding="16,0">
                            <Entry x:Name="ServerUrlEntry"
                                   Placeholder="https://dein-server:8080"
                                   PlaceholderColor="{DynamicResource TextMuted}"
                                   TextColor="{DynamicResource TextPrimary}"
                                   FontSize="14"
                                   HeightRequest="50"
                                   BackgroundColor="Transparent"
                                   Keyboard="Url"
                                   ReturnType="Next"
                                   Completed="OnServerUrlCompleted"
                                   Unfocused="OnServerUrlUnfocused" />
                        </Border>
                    </VerticalStackLayout>

                    <!-- Verbindungsstatus -->
                    <Border x:Name="StatusBorder"
                            BackgroundColor="{DynamicResource SurfaceColor}"
                            Stroke="{DynamicResource BorderColor}" StrokeThickness="1"
                            StrokeShape="RoundRectangle 12" Padding="14,10">
                        <HorizontalStackLayout Spacing="8" HorizontalOptions="Center">
                            <Label x:Name="StatusDot" Text="●" FontSize="11"
                                   TextColor="{DynamicResource TextMuted}"
                                   VerticalOptions="Center" />
                            <Label x:Name="StatusLabel" Text="Bitte Server-URL eingeben"
                                   FontSize="13" TextColor="{DynamicResource TextMuted}"
                                   VerticalOptions="Center" />
                        </HorizontalStackLayout>
                    </Border>

                    <!-- Benutzername -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="BENUTZERNAME"
                               FontSize="11" FontAttributes="Bold"
                               TextColor="{DynamicResource TextMuted}"
                               CharacterSpacing="1.2" />
                        <Border BackgroundColor="{DynamicResource CardColor}"
                                Stroke="{DynamicResource BorderColor}" StrokeThickness="1"
                                StrokeShape="RoundRectangle 14" Padding="16,0">
                            <Entry x:Name="UsernameEntry"
                                   Placeholder="Benutzername"
                                   PlaceholderColor="{DynamicResource TextMuted}"
                                   TextColor="{DynamicResource TextPrimary}"
                                   FontSize="15"
                                   HeightRequest="50"
                                   BackgroundColor="Transparent"
                                   ReturnType="Next"
                                   Keyboard="Text" />
                        </Border>
                    </VerticalStackLayout>

                    <!-- Passwort -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="PASSWORT"
                               FontSize="11" FontAttributes="Bold"
                               TextColor="{DynamicResource TextMuted}"
                               CharacterSpacing="1.2" />
                        <Border BackgroundColor="{DynamicResource CardColor}"
                                Stroke="{DynamicResource BorderColor}" StrokeThickness="1"
                                StrokeShape="RoundRectangle 14" Padding="16,0">
                            <Entry x:Name="PasswordEntry"
                                   Placeholder="Dein Passwort"
                                   PlaceholderColor="{DynamicResource TextMuted}"
                                   TextColor="{DynamicResource TextPrimary}"
                                   FontSize="15"
                                   HeightRequest="50"
                                   BackgroundColor="Transparent"
                                   IsPassword="True"
                                   ReturnType="Done" />
                        </Border>
                    </VerticalStackLayout>

                    <!-- Eingeloggt bleiben -->
                    <HorizontalStackLayout Spacing="10" Margin="2,6,0,0">
                        <CheckBox x:Name="RememberMeCheckBox"
                                  IsChecked="True"
                                  Color="{StaticResource Primary}"
                                  VerticalOptions="Center" />
                        <Label Text="Eingeloggt bleiben"
                               FontSize="14"
                               TextColor="{DynamicResource TextSecondary}"
                               VerticalOptions="Center" />
                    </HorizontalStackLayout>

                    <!-- Lockout-Anzeige -->
                    <Border x:Name="LockoutBanner"
                            BackgroundColor="#2A1515"
                            Stroke="{StaticResource Accent}"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 12"
                            Padding="14,10"
                            IsVisible="False">
                        <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                            <Label Text="🔒" FontSize="18" VerticalOptions="Center"/>
                            <VerticalStackLayout Spacing="2" VerticalOptions="Center">
                                <Label Text="Zu viele Fehlversuche"
                                       FontSize="13" FontAttributes="Bold"
                                       TextColor="{StaticResource Accent}" />
                                <Label x:Name="LockoutLabel"
                                       Text=""
                                       FontSize="12"
                                       TextColor="{DynamicResource TextSecondary}" />
                            </VerticalStackLayout>
                        </HorizontalStackLayout>
                    </Border>

                    <!-- Fehler -->
                    <Label x:Name="ErrorLabel"
                           Text=""
                           FontSize="13"
                           TextColor="{StaticResource Accent}"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center"
                           IsVisible="False" />

                    <!-- Login-Button -->
                    <Button x:Name="LoginButton"
                            Text="🔓  Anmelden"
                            Clicked="OnLoginClicked"
                            BackgroundColor="{StaticResource Primary}"
                            TextColor="{DynamicResource TextPrimary}"
                            FontSize="16" FontAttributes="Bold"
                            HeightRequest="54" CornerRadius="16"
                            HorizontalOptions="Fill"
                            Margin="0,8,0,0" />

                    <!-- Biometrie-Button -->
                    <Button x:Name="BiometricButton"
                            Text="🔐  Mit Biometrie entsperren"
                            Clicked="OnBiometricClicked"
                            BackgroundColor="{DynamicResource CardColor}"
                            TextColor="{DynamicResource TextSecondary}"
                            FontSize="14"
                            HeightRequest="48" CornerRadius="16"
                            BorderColor="{DynamicResource BorderColor}"
                            BorderWidth="1"
                            HorizontalOptions="Fill"
                            IsVisible="False" />

                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
