<?xml version="1.0" encoding="utf-8" ?><ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui" xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml" xmlns:vm="clr-namespace:VERA.ViewModels" x:Class="VERA.Views.EditEntryPage" x:DataType="vm:EditEntryViewModel" BackgroundColor="{DynamicResource AppBackground}" Title="{Binding PageTitle}"><ScrollView><VerticalStackLayout Spacing="0"><Grid Padding="8,48,20,16" ColumnDefinitions="56,*,Auto"><Button Grid.Column="0" Text="&#8592;" FontSize="22" TextColor="{DynamicResource TextPrimary}" BackgroundColor="Transparent" Clicked="OnBackClicked" VerticalOptions="Center" /><Label Grid.Column="1" Text="{Binding PageTitle}" FontSize="22" FontAttributes="Bold" TextColor="{DynamicResource TextPrimary}" VerticalOptions="Center" /><Button Grid.Column="2" Text="Speichern" Command="{Binding SaveCommand}" BackgroundColor="{StaticResource Primary}" TextColor="{DynamicResource TextPrimary}" FontSize="14" FontAttributes="Bold" CornerRadius="10" Padding="14,8" VerticalOptions="Center" /></Grid><Label Text="TYP" FontSize="11" FontAttributes="Bold" TextColor="{DynamicResource TextMuted}" Margin="20,20,20,6" CharacterSpacing="1.5" IsVisible="{Binding IsNew}" /><Border Margin="16,0" BackgroundColor="{DynamicResource CardColor}" Stroke="{DynamicResource BorderColor}" StrokeThickness="1" StrokeShape="RoundRectangle 14" Padding="16,4" IsVisible="{Binding IsNew}"><Picker ItemsSource="{Binding EntryTypes}" SelectedIndex="{Binding SelectedTypeIndex}" TextColor="{DynamicResource TextPrimary}" BackgroundColor="Transparent" FontSize="15" /></Border><Label Text="START" FontSize="11" FontAttributes="Bold" TextColor="{DynamicResource TextMuted}" Margin="20,20,20,6" CharacterSpacing="1.5" IsVisible="{Binding ShowTimePickers}" /><Border Margin="16,0" BackgroundColor="{DynamicResource CardColor}" Stroke="{DynamicResource BorderColor}" StrokeThickness="1" StrokeShape="RoundRectangle 14" Padding="20,6" IsVisible="{Binding ShowTimePickers}"><VerticalStackLayout Spacing="0"><Grid ColumnDefinitions="*,Auto" Padding="0,8"><Label Grid.Column="0" Text="Datum" FontSize="15" TextColor="{DynamicResource TextSecondary}" VerticalOptions="Center" /><DatePicker Grid.Column="1" Date="{Binding StartDate}" TextColor="{DynamicResource TextPrimary}" BackgroundColor="Transparent" FontSize="15" /></Grid><BoxView HeightRequest="1" BackgroundColor="{DynamicResource BorderColor}" /><Grid ColumnDefinitions="*,Auto" Padding="0,8"><Label Grid.Column="0" Text="Uhrzeit" FontSize="15" TextColor="{DynamicResource TextSecondary}" VerticalOptions="Center" /><TimePicker Grid.Column="1" Time="{Binding StartTime}" TextColor="{DynamicResource TextPrimary}" BackgroundColor="Transparent" Format="HH:mm" FontSize="15" /></Grid></VerticalStackLayout></Border><Label Text="DATUM" FontSize="11" FontAttributes="Bold" TextColor="{DynamicResource TextMuted}" Margin="20,20,20,6" CharacterSpacing="1.5" IsVisible="{Binding ShowTimePickers, Converter={StaticResource InverseBoolConverter}}" /><Border Margin="16,0" BackgroundColor="{DynamicResource CardColor}" Stroke="{DynamicResource BorderColor}" StrokeThickness="1" StrokeShape="RoundRectangle 14" Padding="20,6" IsVisible="{Binding ShowTimePickers, Converter={StaticResource InverseBoolConverter}}"><Grid ColumnDefinitions="*,Auto" Padding="0,8"><Label Grid.Column="0" Text="Datum" FontSize="15" TextColor="{DynamicResource TextSecondary}" VerticalOptions="Center" /><DatePicker Grid.Column="1" Date="{Binding StartDate}" TextColor="{DynamicResource TextPrimary}" BackgroundColor="Transparent" FontSize="15" /></Grid></Border><Label Text="ENDE" FontSize="11" FontAttributes="Bold" TextColor="{DynamicResource TextMuted}" Margin="20,20,20,6" CharacterSpacing="1.5" IsVisible="{Binding ShowTimePickers}" /><Border Margin="16,0,16,36" BackgroundColor="{DynamicResource CardColor}" Stroke="{DynamicResource BorderColor}" StrokeThickness="1" StrokeShape="RoundRectangle 14" Padding="20,6" IsVisible="{Binding ShowTimePickers}"><Verti