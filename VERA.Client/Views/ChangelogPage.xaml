<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:VERA.Views"
             x:Class="VERA.Views.ChangelogPage"
             BackgroundColor="{StaticResource AppBackground}"
             Title="Changelog">

    <Grid RowDefinitions="Auto,*">

        <!-- Header -->
        <Grid Grid.Row="0" Padding="8,48,20,16" ColumnDefinitions="56,*,Auto">
            <Button Grid.Column="0"
                    Text="&#8592;"
                    FontSize="22"
                    TextColor="{StaticResource TextPrimary}"
                    BackgroundColor="Transparent"
                    Clicked="OnBackClicked"
                    VerticalOptions="Center" />
            <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                <Label Text="Changelog"
                       FontSize="22" FontAttributes="Bold"
                       TextColor="{StaticResource TextPrimary}" />
                <Label Text="Versionshistorie"
                       FontSize="11"
                       TextColor="{StaticResource TextMuted}" />
            </VerticalStackLayout>
            <!-- Anzahl Releases Badge -->
            <Border Grid.Column="2"
                    BackgroundColor="{StaticResource SurfaceColor}"
                    Stroke="{StaticResource BorderColor}"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 10"
                    Padding="10,5"
                    VerticalOptions="Center">
                <Label x:Name="ReleaseBadgeLabel"
                       FontSize="11" FontAttributes="Bold"
                       TextColor="{StaticResource TextSecondary}" />
            </Border>
        </Grid>

        <!-- Release-Liste -->
        <CollectionView x:Name="ReleasesView"
                        Grid.Row="1"
                        Margin="0,0,0,0">
            <CollectionView.Header>
                <BoxView HeightRequest="4" Color="Transparent" />
            </CollectionView.Header>
            <CollectionView.Footer>
                <BoxView HeightRequest="32" Color="Transparent" />
            </CollectionView.Footer>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="local:ChangelogRelease">
                    <VerticalStackLayout Padding="16,0,16,12" Spacing="0">

                        <!-- Release-Header-Karte -->
                        <Border BackgroundColor="{Binding HeaderBackground}"
                                Stroke="{Binding HeaderBorderColor}"
                                StrokeThickness="1.5"
                                StrokeShape="RoundRectangle 16,16,0,0"
                                Padding="18,14">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                <VerticalStackLayout Grid.Column="0" Spacing="4">
                                    <HorizontalStackLayout Spacing="8">
                                        <!-- Aktuell-Badge -->
                                        <Border BackgroundColor="{Binding CurrentBadgeBackground}"
                                                StrokeThickness="0"
                                                StrokeShape="RoundRectangle 6"
                                                Padding="6,2"
                                                IsVisible="{Binding IsCurrent}">
                                            <Label Text="● AKTUELL"
                                                   FontSize="9" FontAttributes="Bold"
                                                   TextColor="#4ECCA3"
                                                   CharacterSpacing="1" />
                                        </Border>
                                        <Label Text="{Binding Version}"
                                               FontSize="20" FontAttributes="Bold"
                                               TextColor="{Binding VersionColor}"
                                               VerticalOptions="Center" />
                                    </HorizontalStackLayout>
                                    <Label Text="{Binding DateDisplay}"
                                           FontSize="11"
                                           TextColor="{Binding DateColor}" />
                                </VerticalStackLayout>
                                <!-- Stats: Added / Fixed / Changed -->
                                <HorizontalStackLayout Grid.Column="1" Spacing="6" VerticalOptions="Center">
                                    <Border BackgroundColor="#112210"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 8"
                                            Padding="7,3"
                                            IsVisible="{Binding HasAdded}">
                                        <Label Text="{Binding AddedCountLabel}"
                                               FontSize="10" FontAttributes="Bold"
                                               TextColor="#4ECCA3" />
                                    </Border>
                                    <Border BackgroundColor="#231218"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 8"
                                            Padding="7,3"
                                            IsVisible="{Binding HasFixed}">
                                        <Label Text="{Binding FixedCountLabel}"
                                               FontSize="10" FontAttributes="Bold"
                                               TextColor="#FF7096" />
                                    </Border>
                                    <Border BackgroundColor="#12162A"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 8"
                                            Padding="7,3"
                                            IsVisible="{Binding HasChanged}">
                                        <Label Text="{Binding ChangedCountLabel}"
                                               FontSize="10" FontAttributes="Bold"
                                               TextColor="{StaticResource TextSecondary}" />
                                    </Border>
                                </HorizontalStackLayout>
                            </Grid>
                        </Border>

                        <!-- Section-Inhalte -->
                        <Border BackgroundColor="{StaticResource CardColor}"
                                Stroke="{Binding HeaderBorderColor}"
                                StrokeThickness="1.5"
                                StrokeShape="RoundRectangle 0,0,16,16"
                                Padding="18,12,18,16">
                            <VerticalStackLayout Spacing="10">

                                <!-- Added -->
                                <VerticalStackLayout Spacing="6" IsVisible="{Binding HasAdded}">
                                    <HorizontalStackLayout Spacing="8">
                                        <Border BackgroundColor="#1A3020"
                                                StrokeThickness="0"
                                                StrokeShape="RoundRectangle 6"
                                                Padding="8,3">
                                            <Label Text="✦ NEU"
                                                   FontSize="9" FontAttributes="Bold"
                                                   TextColor="#4ECCA3"
                                                   CharacterSpacing="1.5" />
                                        </Border>
                                    </HorizontalStackLayout>
                                    <CollectionView ItemsSource="{Binding AddedItems}"
                                                    SelectionMode="None">
                                        <CollectionView.ItemTemplate>
                                            <DataTemplate x:DataType="local:ChangelogItem">
                                                <Grid ColumnDefinitions="16,*" ColumnSpacing="8"
                                                      Margin="0,2">
                                                    <Label Grid.Column="0"
                                                           Text="+"
                                                           FontSize="13" FontAttributes="Bold"
                                                           TextColor="#4ECCA3"
                                                           VerticalOptions="Start"
                                                           Margin="0,1,0,0" />
                                                    <VerticalStackLayout Grid.Column="1" Spacing="1">
                                                        <Label Text="{Binding Title}"
                                                               FontSize="13" FontAttributes="Bold"
                                                               TextColor="{StaticResource TextPrimary}"
                                                               IsVisible="{Binding HasTitle}" />
                                                        <Label Text="{Binding Body}"
                                                               FontSize="12"
                                                               TextColor="{StaticResource TextSecondary}"
                                                               LineBreakMode="WordWrap" />
                                                    </VerticalStackLayout>
                                                </Grid>
                                            </DataTemplate>
                                        </CollectionView.ItemTemplate>
                                    </CollectionView>
                                </VerticalStackLayout>

                                <!-- Trennlinie Added→Fixed -->
                                <BoxView HeightRequest="1"
                                         Color="{StaticResource DividerColor}"
                                         IsVisible="{Binding HasAddedAndFixed}" />

                                <!-- Fixed -->
                                <VerticalStackLayout Spacing="6" IsVisible="{Binding HasFixed}">
                                    <HorizontalStackLayout Spacing="8">
                                        <Border BackgroundColor="#2A1020"
                                                StrokeThickness="0"
                                                StrokeShape="RoundRectangle 6"
                                                Padding="8,3">
                                            <Label Text="⬡ FIX"
                                                   FontSize="9" FontAttributes="Bold"
                                                   TextColor="#FF7096"
                                                   CharacterSpacing="1.5" />
                                        </Border>
                                    </HorizontalStackLayout>
                                    <CollectionView ItemsSource="{Binding FixedItems}"
                                                    SelectionMode="None">
                                        <CollectionView.ItemTemplate>
                                            <DataTemplate x:DataType="local:ChangelogItem">
                                                <Grid ColumnDefinitions="16,*" ColumnSpacing="8"
                                                      Margin="0,2">
                                                    <Label Grid.Column="0"
                                                           Text="×"
                                                           FontSize="13" FontAttributes="Bold"
                                                           TextColor="#FF7096"
                                                           VerticalOptions="Start"
                                                           Margin="0,1,0,0" />
                                                    <VerticalStackLayout Grid.Column="1" Spacing="1">
                                                        <Label Text="{Binding Title}"
                                                               FontSize="13" FontAttributes="Bold"
                                                               TextColor="{StaticResource TextPrimary}"
                                                               IsVisible="{Binding HasTitle}" />
                                                        <Label Text="{Binding Body}"
                                                               FontSize="12"
                                                               TextColor="{StaticResource TextSecondary}"
                                                               LineBreakMode="WordWrap" />
                                                    </VerticalStackLayout>
                                                </Grid>
                                            </DataTemplate>
                                        </CollectionView.ItemTemplate>
                                    </CollectionView>
                                </VerticalStackLayout>

                                <!-- Trennlinie →Changed -->
                                <BoxView HeightRequest="1"
                                         Color="{StaticResource DividerColor}"
                                         IsVisible="{Binding HasFixedAndChanged}" />

                                <!-- Changed -->
                                <VerticalStackLayout Spacing="6" IsVisible="{Binding HasChanged}">
                                    <HorizontalStackLayout Spacing="8">
                                        <Border BackgroundColor="#12162A"
                                                StrokeThickness="0"
                                                StrokeShape="RoundRectangle 6"
                                                Padding="8,3">
                                            <Label Text="↻ ÄNDERUNG"
                                                   FontSize="9" FontAttributes="Bold"
                                                   TextColor="{StaticResource TextSecondary}"
                                                   CharacterSpacing="1.5" />
                                        </Border>
                                    </HorizontalStackLayout>
                                    <CollectionView ItemsSource="{Binding ChangedItems}"
                                                    SelectionMode="None">
                                        <CollectionView.ItemTemplate>
                                            <DataTemplate x:DataType="local:ChangelogItem">
                                                <Grid ColumnDefinitions="16,*" ColumnSpacing="8"
                                                      Margin="0,2">
                                                    <Label Grid.Column="0"
                                                           Text="~"
                                                           FontSize="13" FontAttributes="Bold"
                                                           TextColor="{StaticResource TextSecondary}"
                                                           VerticalOptions="Start"
                                                           Margin="0,1,0,0" />
                                                    <VerticalStackLayout Grid.Column="1" Spacing="1">
                                                        <Label Text="{Binding Title}"
                                                               FontSize="13" FontAttributes="Bold"
                                                               TextColor="{StaticResource TextPrimary}"
                                                               IsVisible="{Binding HasTitle}" />
                                                        <Label Text="{Binding Body}"
                                                               FontSize="12"
                                                               TextColor="{StaticResource TextSecondary}"
                                                               LineBreakMode="WordWrap" />
                                                    </VerticalStackLayout>
                                                </Grid>
                                            </DataTemplate>
                                        </CollectionView.ItemTemplate>
                                    </CollectionView>
                                </VerticalStackLayout>

                            </VerticalStackLayout>
                        </Border>

                    </VerticalStackLayout>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>

</ContentPage>
