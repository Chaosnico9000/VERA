<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VERA.Views.ChangelogPage"
             BackgroundColor="{StaticResource AppBackground}"
             Title="Changelog">

    <Grid RowDefinitions="Auto,*">

        <!-- Header -->
        <Grid Grid.Row="0" Padding="8,48,20,16" ColumnDefinitions="56,*">
            <Button Grid.Column="0" Text="&#8592;" FontSize="22"
                    TextColor="{StaticResource TextPrimary}" BackgroundColor="Transparent"
                    Clicked="OnBackClicked" VerticalOptions="Center" />
            <VerticalStackLayout Grid.Column="1" Spacing="1" VerticalOptions="Center">
                <Label Text="Changelog" FontSize="22" FontAttributes="Bold"
                       TextColor="{StaticResource TextPrimary}" />
                <Label Text="Was hat sich geändert?" FontSize="11" TextColor="{StaticResource TextMuted}" />
            </VerticalStackLayout>
        </Grid>

        <!-- Inhalt -->
        <ScrollView Grid.Row="1" Padding="16,0,16,32">
            <Label x:Name="ChangelogLabel"
                   FontSize="13"
                   TextColor="{StaticResource TextSecondary}"
                   FontFamily="Monospace"
                   LineBreakMode="WordWrap" />
        </ScrollView>

    </Grid>

</ContentPage>
