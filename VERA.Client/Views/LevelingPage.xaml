<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:VERA.ViewModels"
             xmlns:svc="clr-namespace:VERA.Services"
             x:Class="VERA.Views.LevelingPage"
             x:DataType="vm:GamificationViewModel"
             BackgroundColor="{DynamicResource AppBackground}"
             Title="Leveling">

    <Grid RowDefinitions="Auto,*">

        <!-- Header -->
        <Grid Grid.Row="0" Padding="8,48,20,12" ColumnDefinitions="56,*,Auto">
            <Button Grid.Column="0"
                    Text="&#9776;"
                    FontSize="22"
                    TextColor="{DynamicResource TextPrimary}"
                    BackgroundColor="Transparent"
                    Clicked="OnMenuClicked"
                    VerticalOptions="Center" />
            <VerticalStackLayout Grid.Column="1" Spacing="1" VerticalOptions="Center">
                <Label Text="Leveling"
                       FontSize="22" FontAttributes="Bold"
                       TextColor="{DynamicResource TextPrimary}" />
                <Label Text="{Binding TotalXPLabel}"
                       FontSize="11"
                       TextColor="{DynamicResource TextMuted}" />
            </VerticalStackLayout>
            <!-- Rang-Badge Header -->
            <Border Grid.Column="2"
                    BackgroundColor="{DynamicResource CardColor}"
                    Stroke="{Binding RangFarbe}"
                    StrokeThickness="1.5"
                    StrokeShape="RoundRectangle 10"
                    Padding="10,5"
                    VerticalOptions="Center">
                <Label Text="{Binding RangTitel}"
                       FontSize="12" FontAttributes="Bold"
                       TextColor="{Binding RangFarbe}" />
            </Border>
        </Grid>

        <!-- Inhalt scrollbar -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="14" Padding="16,0,16,32">

                <!-- ═══ Hero-Karte: Level + XP ═══ -->
                <Border BackgroundColor="{DynamicResource CardColor}"
                        Stroke="{Binding RangFarbe}"
                        StrokeThickness="1.5"
                        StrokeShape="RoundRectangle 22"
                        Padding="24,22">
                    <VerticalStackLayout Spacing="16">

                        <!-- Emoji + Name + Rang -->
                        <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                            <Label x:Name="HeroEmoji"
                                   Text="{Binding LevelEmoji}"
                                   FontSize="56"
                                   HorizontalOptions="Center" />
                            <Label Text="{Binding LevelTitle}"
                                   FontSize="24" FontAttributes="Bold"
                                   TextColor="{DynamicResource TextPrimary}"
                                   HorizontalOptions="Center" />
                            <HorizontalStackLayout HorizontalOptions="Center" Spacing="8">
                                <Label FontSize="14" TextColor="{DynamicResource TextMuted}">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="Level " TextColor="{DynamicResource TextMuted}" FontSize="14"/>
                                            <Span Text="{Binding Level}" TextColor="{Binding RangFarbe}"
                                                  FontAttributes="Bold" FontSize="16"/>
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>
                                <Label Text="·" FontSize="14" TextColor="{DynamicResource TextMuted}" VerticalOptions="Center"/>
                                <Label Text="{Binding RangEmoji}" FontSize="14" VerticalOptions="Center"/>
                                <Label Text="{Binding RangTitel}"
                                       FontSize="14" FontAttributes="Bold"
                                       TextColor="{Binding RangFarbe}"
                                       VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                        </VerticalStackLayout>

                        <!-- XP-Fortschrittsbalken -->
                        <VerticalStackLayout Spacing="8">
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Grid.Column="0" FontSize="13">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="{Binding XPInLevel, StringFormat='{0:N0}'}"
                                                  TextColor="{Binding ProgressColor}" FontAttributes="Bold" FontSize="14"/>
                                            <Span Text=" / " TextColor="{DynamicResource TextMuted}" FontSize="13"/>
                                            <Span Text="{Binding XPForNextLevel, StringFormat='{0:N0}'}"
                                                  TextColor="{DynamicResource TextMuted}" FontSize="13"/>
                                            <Span Text=" XP" TextColor="{DynamicResource TextMuted}" FontSize="13"/>
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>
                                <Label Grid.Column="1"
                                       FontSize="12" TextColor="{DynamicResource TextMuted}"
                                       VerticalOptions="Center">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="{Binding LevelProgress, StringFormat='{0:P0}'}"
                                                  TextColor="{Binding ProgressColor}" FontAttributes="Bold"/>
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>
                            </Grid>
                            <ProgressBar x:Name="XpBar"
                                         Progress="{Binding LevelProgress}"
                                         ProgressColor="{Binding ProgressColor}"
                                         BackgroundColor="{DynamicResource SurfaceColor}"
                                         HeightRequest="12" />
                        </VerticalStackLayout>

                    </VerticalStackLayout>
                </Border>

                <!-- ═══ Stats-Raster ═══ -->
                <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="10" RowSpacing="10">

                    <!-- Arbeitstage -->
                    <Border Grid.Column="0" Grid.Row="0"
                            BackgroundColor="{DynamicResource CardColor}"
                            Stroke="{DynamicResource BorderColor}" StrokeThickness="1"
                            StrokeShape="RoundRectangle 14" Padding="16,14">
                        <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                            <Label Text="📅" FontSize="22" HorizontalOptions="Center"/>
                            <Label Text="{Binding Arbeitstage}"
                                   FontSize="26" FontAttributes="Bold"
                                   TextColor="{DynamicResource TextPrimary}"
                                   HorizontalOptions="Center" />
                            <Label Text="Arbeitstage"
                                   FontSize="11" TextColor="{DynamicResource TextMuted}"
                                   HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </Border>

                    <!-- Gesamtzeit -->
                    <Border Grid.Column="1" Grid.Row="0"
                            BackgroundColor="{DynamicResource CardColor}"
                            Stroke="{DynamicResource BorderColor}" StrokeThickness="1"
                            StrokeShape="RoundRectangle 14" Padding="16,14">
                        <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                            <Label Text="⏱️" FontSize="22" HorizontalOptions="Center"/>
                            <Label Text="{Binding ArbeitszeitGesamt}"
                                   FontSize="26" FontAttributes="Bold"
                                   TextColor="{StaticResource CyanColor}"
                                   HorizontalOptions="Center" />
                            <Label Text="Gesamtzeit"
                                   FontSize="11" TextColor="{DynamicResource TextMuted}"
                                   HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </Border>

                    <!-- Streak -->
                    <Border Grid.Column="0" Grid.Row="1"
                            BackgroundColor="{DynamicResource CardColor}"
                            Stroke="{DynamicResource BorderColor}" StrokeThickness="1"
                            StrokeShape="RoundRectangle 14" Padding="16,14">
                        <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                            <Label Text="{Binding StreakFlame}" FontSize="22" HorizontalOptions="Center"/>
                            <HorizontalStackLayout HorizontalOptions="Center" Spacing="4">
                                <Label Text="{Binding Streak}"
                                       FontSize="26" FontAttributes="Bold"
                                       TextColor="{StaticResource WarningColor}"
                                       VerticalOptions="Center"/>
                                <Label Text="W" FontSize="14"
                                       TextColor="{StaticResource WarningColor}"
                                       VerticalOptions="End" Margin="0,0,0,4"/>
                            </HorizontalStackLayout>
                            <Label Text="{Binding BesterStreakLabel}"
                                   FontSize="11" TextColor="{DynamicResource TextMuted}"
                                   HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </Border>

                    <!-- Achievements -->
                    <Border Grid.Column="1" Grid.Row="1"
                            BackgroundColor="{DynamicResource CardColor}"
                            Stroke="{DynamicResource BorderColor}" StrokeThickness="1"
                            StrokeShape="RoundRectangle 14" Padding="16,14">
                        <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                            <Label Text="🏅" FontSize="22" HorizontalOptions="Center"/>
                            <Label Text="{Binding AchievementLabel}"
                                   FontSize="22" FontAttributes="Bold"
                                   TextColor="{StaticResource WarningColor}"
                                   HorizontalOptions="Center" />
                            <Label Text="Erfolge"
                                   FontSize="11" TextColor="{DynamicResource TextMuted}"
                                   HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </Border>

                </Grid>

                <!-- ═══ Achievements Liste ═══ -->
                <Border BackgroundColor="{DynamicResource CardColor}"
                        Stroke="{DynamicResource BorderColor}" StrokeThickness="1"
                        StrokeShape="RoundRectangle 18" Padding="20,16">
                    <VerticalStackLayout Spacing="12">

                        <Label Text="🏅  ERFOLGE"
                               FontSize="12" FontAttributes="Bold"
                               TextColor="{DynamicResource TextMuted}"
                               CharacterSpacing="1.5" />

                        <CollectionView ItemsSource="{Binding Achievements}">
                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout Orientation="Vertical" ItemSpacing="8"/>
                            </CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="svc:Achievement">
                                    <Border BackgroundColor="{DynamicResource SurfaceColor}"
                                            Stroke="{DynamicResource BorderColor}"
                                            StrokeThickness="1"
                                            StrokeShape="RoundRectangle 12"
                                            Padding="14,10"
                                            Opacity="{Binding Erreicht, Converter={StaticResource BoolToOpacityConverter}}">
                                        <Grid ColumnDefinitions="44,*,Auto">
                                            <!-- Emoji-Badge -->
                                            <Border Grid.Column="0"
                                                    BackgroundColor="{DynamicResource CardColor}"
                                                    Stroke="{DynamicResource BorderColor}"
                                                    StrokeThickness="1"
                                                    StrokeShape="RoundRectangle 10"
                                                    WidthRequest="38" HeightRequest="38"
                                                    HorizontalOptions="Center"
                                                    VerticalOptions="Center">
                                                <Label Text="{Binding Emoji}"
                                                       FontSize="18"
                                                       HorizontalOptions="Center"
                                                       VerticalOptions="Center" />
                                            </Border>
                                            <!-- Titel + Beschreibung -->
                                            <VerticalStackLayout Grid.Column="1"
                                                                 Spacing="2"
                                                                 VerticalOptions="Center"
                                                                 Margin="10,0,0,0">
                                                <Label Text="{Binding Titel}"
                                                       FontSize="14" FontAttributes="Bold"
                                                       TextColor="{DynamicResource TextPrimary}"
                                                       LineBreakMode="TailTruncation" />
                                                <Label Text="{Binding Beschreibung}"
                                                       FontSize="11"
                                                       TextColor="{DynamicResource TextMuted}"
                                                       LineBreakMode="TailTruncation" />
                                            </VerticalStackLayout>
                                            <!-- Erreicht-Haken -->
                                            <Label Grid.Column="2"
                                                   Text="✓"
                                                   FontSize="18" FontAttributes="Bold"
                                                   TextColor="{StaticResource SuccessColor}"
                                                   VerticalOptions="Center"
                                                   IsVisible="{Binding Erreicht}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                    </VerticalStackLayout>
                </Border>

                <!-- ═══ XP-Aufschlüsselung ═══ -->
                <Border BackgroundColor="{DynamicResource CardColor}"
                        Stroke="{DynamicResource BorderColor}" StrokeThickness="1"
                        StrokeShape="RoundRectangle 18" Padding="20,16">
                    <VerticalStackLayout Spacing="10">

                        <Label Text="⚡  XP-HERKUNFT"
                               FontSize="12" FontAttributes="Bold"
                               TextColor="{DynamicResource TextMuted}"
                               CharacterSpacing="1.5" />

                        <BoxView HeightRequest="1"
                                 BackgroundColor="{DynamicResource BorderColor}"
                                 Margin="0,0,0,2"/>

                        <!-- Zeilen -->
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                            <Label Grid.Column="0" Text="💼" FontSize="16" VerticalOptions="Center"/>
                            <Label Grid.Column="1" Text="Arbeitszeit"
                                   FontSize="13" TextColor="{DynamicResource TextSecondary}"
                                   VerticalOptions="Center"/>
                            <Label Grid.Column="2"
                                   Text="{Binding XpAusArbeitLabel}"
                                   FontSize="13" FontAttributes="Bold"
                                   TextColor="{DynamicResource TextPrimary}"
                                   VerticalOptions="Center"/>
                        </Grid>
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                            <Label Grid.Column="0" Text="🌴" FontSize="16" VerticalOptions="Center"/>
                            <Label Grid.Column="1" Text="Sondertage"
                                   FontSize="13" TextColor="{DynamicResource TextSecondary}"
                                   VerticalOptions="Center"/>
                            <Label Grid.Column="2"
                                   Text="{Binding XpAusSonderLabel}"
                                   FontSize="13" FontAttributes="Bold"
                                   TextColor="{DynamicResource TextPrimary}"
                                   VerticalOptions="Center"/>
                        </Grid>
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                            <Label Grid.Column="0" Text="🔥" FontSize="16" VerticalOptions="Center"/>
                            <Label Grid.Column="1" Text="Streak"
                                   FontSize="13" TextColor="{DynamicResource TextSecondary}"
                                   VerticalOptions="Center"/>
                            <Label Grid.Column="2"
                                   Text="{Binding XpAusStreakLabel}"
                                   FontSize="13" FontAttributes="Bold"
                                   TextColor="{StaticResource WarningColor}"
                                   VerticalOptions="Center"/>
                        </Grid>
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                            <Label Grid.Column="0" Text="🏅" FontSize="16" VerticalOptions="Center"/>
                            <Label Grid.Column="1" Text="Achievements"
                                   FontSize="13" TextColor="{DynamicResource TextSecondary}"
                                   VerticalOptions="Center"/>
                            <Label Grid.Column="2"
                                   Text="{Binding XpAusAchievementsLabel}"
                                   FontSize="13" FontAttributes="Bold"
                                   TextColor="{StaticResource WarningColor}"
                                   VerticalOptions="Center"/>
                        </Grid>
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                            <Label Grid.Column="0" Text="🎂" FontSize="16" VerticalOptions="Center"/>
                            <Label Grid.Column="1" Text="Jubiläum"
                                   FontSize="13" TextColor="{DynamicResource TextSecondary}"
                                   VerticalOptions="Center"/>
                            <Label Grid.Column="2"
                                   Text="{Binding XpAusJubilaeumLabel}"
                                   FontSize="13" FontAttributes="Bold"
                                   TextColor="{StaticResource CyanColor}"
                                   VerticalOptions="Center"/>
                        </Grid>

                        <BoxView HeightRequest="1"
                                 BackgroundColor="{DynamicResource BorderColor}"
                                 Margin="0,2,0,0"/>

                        <Grid ColumnDefinitions="*,Auto">
                            <Label Grid.Column="0" Text="Gesamt"
                                   FontSize="14" FontAttributes="Bold"
                                   TextColor="{DynamicResource TextPrimary}"
                                   VerticalOptions="Center"/>
                            <Label Grid.Column="1"
                                   Text="{Binding TotalXPLabel}"
                                   FontSize="15" FontAttributes="Bold"
                                   TextColor="{Binding ProgressColor}"
                                   VerticalOptions="Center"/>
                        </Grid>

                    </VerticalStackLayout>
                </Border>

                <!-- ═══ Nächster Level ═══ -->
                <Border BackgroundColor="{DynamicResource CardColor}"
                        Stroke="{DynamicResource BorderColor}" StrokeThickness="1"
                        StrokeShape="RoundRectangle 18" Padding="20,16">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="🎯  NÄCHSTE MEILENSTEINE"
                               FontSize="12" FontAttributes="Bold"
                               TextColor="{DynamicResource TextMuted}"
                               CharacterSpacing="1.5"/>
                        <CollectionView ItemsSource="{Binding NextMilestones}"
                                        HeightRequest="180">
                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout Orientation="Vertical" ItemSpacing="6"/>
                            </CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="vm:MilestoneEntry">
                                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12" Padding="0,2">
                                        <Label Grid.Column="0"
                                               Text="{Binding Emoji}"
                                               FontSize="20"
                                               VerticalOptions="Center"/>
                                        <VerticalStackLayout Grid.Column="1" Spacing="1" VerticalOptions="Center">
                                            <Label Text="{Binding Titel}"
                                                   FontSize="13" FontAttributes="Bold"
                                                   TextColor="{DynamicResource TextPrimary}"/>
                                            <Label Text="{Binding Beschreibung}"
                                                   FontSize="11"
                                                   TextColor="{DynamicResource TextMuted}"/>
                                        </VerticalStackLayout>
                                        <Label Grid.Column="2"
                                               Text="{Binding XpFehltLabel}"
                                               FontSize="12" FontAttributes="Bold"
                                               TextColor="{DynamicResource TextMuted}"
                                               VerticalOptions="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>
