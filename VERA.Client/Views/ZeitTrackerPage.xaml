<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:VERA.ViewModels"
             xmlns:svc="clr-namespace:VERA.Services"
             xmlns:models="clr-namespace:VERA.Models"
             x:Class="VERA.Views.ZeitTrackerPage"
             x:DataType="vm:DashboardViewModel"
             BackgroundColor="{DynamicResource AppBackground}"
             Title="Zeittracker">

    <Grid RowDefinitions="Auto,*">

        <!-- ── Fixierter Header ─────────────────────────────────────────── -->
        <Grid Grid.Row="0"
              Padding="8,48,16,10"
              ColumnDefinitions="56,*,Auto"
              BackgroundColor="{DynamicResource AppBackground}">

            <Button Grid.Column="0"
                    Text="&#9776;"
                    FontSize="22"
                    TextColor="{DynamicResource TextPrimary}"
                    BackgroundColor="Transparent"
                    Clicked="OnMenuClicked"
                    VerticalOptions="Center" />

            <VerticalStackLayout Grid.Column="1" Spacing="1" VerticalOptions="Center">
                <Label Text="Zeittracker"
                       FontSize="22" FontAttributes="Bold"
                       TextColor="{DynamicResource TextPrimary}" />
                <Label Text="{Binding LastRefreshed}"
                       FontSize="10"
                       TextColor="{DynamicResource TextMuted}" />
            </VerticalStackLayout>

            <!-- Datum + Uhrzeit Badge -->
            <Border Grid.Column="2"
                    BackgroundColor="{DynamicResource CardColor}"
                    Stroke="{DynamicResource BorderColor}"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 12"
                    Padding="10,7"
                    VerticalOptions="Center">
                <VerticalStackLayout Spacing="1" HorizontalOptions="Center">
                    <Label x:Name="DateLabel"
                           FontSize="11"
                           TextColor="{DynamicResource TextSecondary}"
                           HorizontalOptions="Center" />
                    <Label Text="{Binding UhrzeitDisplay}"
                           FontSize="14" FontAttributes="Bold"
                           TextColor="{DynamicResource TextPrimary}"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Border>
        </Grid>

        <!-- ── Scrollbarer Inhalt mit Pull-to-Refresh ──────────────────── -->
        <RefreshView Grid.Row="1"
                     Command="{Binding RefreshCommand}"
                     IsRefreshing="{Binding IsRefreshing}"
                     RefreshColor="{StaticResource CyanColor}">
            <ScrollView>
                <VerticalStackLayout Spacing="0">

                    <!-- Lade-Indikator -->
                    <ActivityIndicator IsRunning="{Binding IsLoading}"
                                       IsVisible="{Binding IsLoading}"
                                       Color="{StaticResource CyanColor}"
                                       HorizontalOptions="Center"
                                       Margin="0,32,0,0" />

                    <!-- ── Timer-Karte ─────────────────────────────────── -->
                    <Border Margin="16,8,16,0"
                            BackgroundColor="{DynamicResource CardColor}"
                            Stroke="{Binding TimerCardBorderColor}"
                            StrokeThickness="1.5"
                            StrokeShape="RoundRectangle 20"
                            IsVisible="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}">
                        <VerticalStackLayout Padding="24,20" Spacing="10">

                            <!-- Große Zeitanzeige -->
                            <Label Text="{Binding TimerDisplay}"
                                   FontSize="48"
                                   FontAttributes="Bold"
                                   TextColor="{DynamicResource TextPrimary}"
                                   HorizontalOptions="Center"
                                   CharacterSpacing="2" />

                            <!-- Status-Zeile -->
                            <HorizontalStackLayout HorizontalOptions="Center" Spacing="6">
                                <!-- Laufend-Punkt -->
                                <Ellipse WidthRequest="7" HeightRequest="7"
                                         Fill="{StaticResource RunningColor}"
                                         VerticalOptions="Center"
                                         IsVisible="{Binding IsRunning}" />
                                <Label FontSize="12"
                                       TextColor="{StaticResource RunningColor}"
                                       VerticalOptions="Center"
                                       IsVisible="{Binding IsRunning}">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="Läuft  ·  " />
                                            <Span Text="{Binding StartZeit}" />
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>
                                <!-- Sondertyp-Hinweis -->
                                <Label Text="🔒 Sondertag eingetragen"
                                       FontSize="12"
                                       TextColor="{StaticResource Accent}"
                                       VerticalOptions="Center"
                                       IsVisible="{Binding TimerGesperrt}" />
                                <!-- Idle-Hinweis -->
                                <Label Text="Bereit zum Starten"
                                       FontSize="12"
                                       TextColor="{DynamicResource TextMuted}"
                                       VerticalOptions="Center"
                                       IsVisible="{Binding IsNotRunning}" />
                            </HorizontalStackLayout>

                            <!-- Motivationstext -->
                            <Label Text="{Binding TagesMotivation}"
                                   FontSize="12"
                                   TextColor="{DynamicResource TextSecondary}"
                                   HorizontalOptions="Center"
                                   HorizontalTextAlignment="Center"
                                   IsVisible="{Binding IsNotRunning}" />

                            <!-- Start / Stopp Button -->
                            <Button Text="{Binding ButtonLabel}"
                                    Command="{Binding ToggleTimerCommand}"
                                    BackgroundColor="{Binding ButtonColor}"
                                    TextColor="{DynamicResource TextPrimary}"
                                    FontSize="17" FontAttributes="Bold"
                                    HeightRequest="54"
                                    CornerRadius="14"
                                    Margin="0,4,0,0"
                                    IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}"
                                    Opacity="{Binding TimerGesperrt, Converter={StaticResource BoolToOpacityConverter}}" />

                        </VerticalStackLayout>
                    </Border>

                    <!-- ── Pausen-Vorschlag Banner ─────────────────────── -->
                    <Border Margin="16,10,16,0"
                            BackgroundColor="#12261C"
                            Stroke="#2A7A55"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 14"
                            Padding="14,11"
                            IsVisible="{Binding PausenVorschlagSichtbar}">
                        <Grid ColumnDefinitions="*,36" ColumnSpacing="6">
                            <Label Grid.Column="0"
                                   Text="{Binding PausenVorschlagText}"
                                   FontSize="13"
                                   TextColor="#4ECCA3"
                                   VerticalOptions="Center" />
                            <Button Grid.Column="1"
                                    Text="✕"
                                    Command="{Binding PauseAbweisenCommand}"
                                    BackgroundColor="Transparent"
                                    TextColor="#4ECCA3"
                                    FontSize="14"
                                    Padding="0"
                                    VerticalOptions="Center"
                                    HorizontalOptions="End" />
                        </Grid>
                    </Border>

                    <!-- ── Tagesfortschritt ────────────────────────────── -->
                    <Border Margin="16,12,16,0"
                            BackgroundColor="{DynamicResource CardColor}"
                            Stroke="{DynamicResource BorderColor}"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 18"
                            Padding="18,16">
                        <VerticalStackLayout Spacing="10">

                            <!-- Label-Zeile -->
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Grid.Column="0"
                                       Text="HEUTE"
                                       FontSize="10" FontAttributes="Bold"
                                       TextColor="{DynamicResource TextMuted}"
                                       CharacterSpacing="1.5"
                                       VerticalOptions="Center" />
                                <Label Grid.Column="1"
                                       Text="{Binding TodayCount, StringFormat='{0} Einträge'}"
                                       FontSize="11"
                                       TextColor="{DynamicResource TextMuted}" />
                            </Grid>

                            <!-- Stunden + Puffer -->
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                <VerticalStackLayout Grid.Column="0" Spacing="1">
                                    <Label Text="{Binding TodayTotal}"
                                           FontSize="28" FontAttributes="Bold"
                                           TextColor="{DynamicResource TextPrimary}" />
                                    <Label FontSize="11" TextColor="{DynamicResource TextMuted}">
                                        <Label.FormattedText>
                                            <FormattedString>
                                                <Span Text="von " />
                                                <Span Text="{Binding SollzeitDisplay}"
                                                      FontAttributes="Bold"
                                                      TextColor="{DynamicResource TextSecondary}" />
                                                <Span Text=" Sollzeit" />
                                            </FormattedString>
                                        </Label.FormattedText>
                                    </Label>
                                </VerticalStackLayout>
                                <Border Grid.Column="1"
                                        BackgroundColor="{DynamicResource SurfaceColor}"
                                        Stroke="{Binding PufferColor}"
                                        StrokeThickness="1"
                                        StrokeShape="RoundRectangle 12"
                                        Padding="12,8"
                                        VerticalOptions="Center">
                                    <Label Text="{Binding PufferDisplay}"
                                           FontSize="15" FontAttributes="Bold"
                                           TextColor="{Binding PufferColor}" />
                                </Border>
                            </Grid>

                            <!-- Fortschrittsbalken -->
                            <ProgressBar Progress="{Binding TodayProgress}"
                                         ProgressColor="{Binding ProgressColor}"
                                         BackgroundColor="{DynamicResource SurfaceColor}"
                                         HeightRequest="8" />

                        </VerticalStackLayout>
                    </Border>

                    <!-- ── Sondertypen eintragen ───────────────────────── -->
                    <Border Margin="16,12,16,0"
                            BackgroundColor="{DynamicResource CardColor}"
                            Stroke="{DynamicResource BorderColor}"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 18"
                            Padding="18,14">
                        <VerticalStackLayout Spacing="10">

                            <Grid ColumnDefinitions="*,Auto">
                                <Label Grid.Column="0"
                                       Text="FÜR HEUTE EINTRAGEN"
                                       FontSize="10" FontAttributes="Bold"
                                       TextColor="{DynamicResource TextMuted}"
                                       CharacterSpacing="1.5"
                                       VerticalOptions="Center" />
                                <!-- Badge wenn Sondertyp vorhanden -->
                                <Border Grid.Column="1"
                                        BackgroundColor="#1A1A40"
                                        Stroke="{StaticResource Accent}"
                                        StrokeThickness="1"
                                        StrokeShape="RoundRectangle 8"
                                        Padding="8,3"
                                        VerticalOptions="Center"
                                        IsVisible="{Binding SondertagHeuteVorhanden}">
                                    <Label Text="{Binding SondertagTitel}"
                                           FontSize="10" FontAttributes="Bold"
                                           TextColor="{StaticResource AccentLight}" />
                                </Border>
                            </Grid>

                            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8"
                                  IsEnabled="{Binding SondertagNichtVorhanden}"
                                  Opacity="{Binding SondertagHeuteVorhanden, Converter={StaticResource BoolToOpacityConverter}}">
                                <Button Grid.Column="0"
                                        Text="🏖 Urlaub&#10;ganztags"
                                        Command="{Binding UrlaubGanztagCommand}"
                                        BackgroundColor="{DynamicResource SurfaceColor}"
                                        TextColor="{DynamicResource TextSecondary}"
                                        FontSize="12" HeightRequest="56"
                                        CornerRadius="12" LineBreakMode="WordWrap"
                                        Padding="4" />
                                <Button Grid.Column="1"
                                        Text="⛅ Urlaub&#10;halbtags"
                                        Command="{Binding UrlaubHalbtagCommand}"
                                        BackgroundColor="{DynamicResource SurfaceColor}"
                                        TextColor="{DynamicResource TextSecondary}"
                                        FontSize="12" HeightRequest="56"
                                        CornerRadius="12" LineBreakMode="WordWrap"
                                        Padding="4" />
                                <Button Grid.Column="2"
                                        Text="🎉 Feiertag"
                                        Command="{Binding FeiertagCommand}"
                                        BackgroundColor="{DynamicResource SurfaceColor}"
                                        TextColor="{DynamicResource TextSecondary}"
                                        FontSize="12" HeightRequest="56"
                                        CornerRadius="12" Padding="4" />
                            </Grid>

                        </VerticalStackLayout>
                    </Border>

                    <!-- ── Wochenübersicht ─────────────────────────────── -->
                    <Border Margin="16,12,16,0"
                            BackgroundColor="{DynamicResource CardColor}"
                            Stroke="{DynamicResource BorderColor}"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 18"
                            Padding="18,14">
                        <VerticalStackLayout Spacing="10">

                            <!-- Header-Zeile -->
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Grid.Column="0"
                                       Text="DIESE WOCHE"
                                       FontSize="10" FontAttributes="Bold"
                                       TextColor="{DynamicResource TextMuted}"
                                       CharacterSpacing="1.5"
                                       VerticalOptions="Center" />
                                <Label Grid.Column="1"
                                       Text="{Binding WochenTageFortschritt}"
                                       FontSize="11"
                                       TextColor="{DynamicResource TextMuted}" />
                            </Grid>

                            <!-- Stunden + Puffer -->
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                <VerticalStackLayout Grid.Column="0" Spacing="1">
                                    <Label Text="{Binding WochenStundenDisplay}"
                                           FontSize="28" FontAttributes="Bold"
                                           TextColor="{DynamicResource TextPrimary}" />
                                    <Label FontSize="11" TextColor="{DynamicResource TextMuted}">
                                        <Label.FormattedText>
                                            <FormattedString>
                                                <Span Text="Ziel " />
                                                <Span Text="{Binding WochenZielDisplay}"
                                                      FontAttributes="Bold"
                                                      TextColor="{DynamicResource TextSecondary}" />
                                                <Span Text=" · 5 Werktage" />
                                            </FormattedString>
                                        </Label.FormattedText>
                                    </Label>
                                </VerticalStackLayout>
                                <Border Grid.Column="1"
                                        BackgroundColor="{DynamicResource SurfaceColor}"
                                        Stroke="{Binding WochenPufferFarbe}"
                                        StrokeThickness="1"
                                        StrokeShape="RoundRectangle 12"
                                        Padding="12,8"
                                        VerticalOptions="Center">
                                    <Label Text="{Binding WochenPufferDisplay}"
                                           FontSize="15" FontAttributes="Bold"
                                           TextColor="{Binding WochenPufferFarbe}" />
                                </Border>
                            </Grid>

                            <!-- Fortschrittsbalken -->
                            <ProgressBar Progress="{Binding WochenProgress}"
                                         ProgressColor="{Binding WochenPufferFarbe}"
                                         BackgroundColor="{DynamicResource SurfaceColor}"
                                         HeightRequest="8" />

                        </VerticalStackLayout>
                    </Border>

                    <!-- ── Gamification-Karte ──────────────────────────── -->
                    <Border x:Name="GamificationCard"
                            Margin="16,12,16,0"
                            BackgroundColor="{DynamicResource CardColor}"
                            Stroke="{DynamicResource BorderColor}"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 18"
                            Padding="18,14">
                        <VerticalStackLayout Spacing="12">

                            <!-- Header: Rang + Titel -->
                            <Grid ColumnDefinitions="Auto,*,Auto">
                                <Border Grid.Column="0"
                                        BackgroundColor="{DynamicResource SurfaceColor}"
                                        Stroke="{Binding Gamification.RangFarbe}"
                                        StrokeThickness="1.5"
                                        StrokeShape="RoundRectangle 8"
                                        Padding="8,4"
                                        VerticalOptions="Center">
                                    <Label Text="{Binding Gamification.RangTitel}"
                                           FontSize="11" FontAttributes="Bold"
                                           TextColor="{Binding Gamification.RangFarbe}" />
                                </Border>
                                <Label Grid.Column="1"
                                       Text="FORTSCHRITT"
                                       FontSize="10" FontAttributes="Bold"
                                       TextColor="{DynamicResource TextMuted}"
                                       CharacterSpacing="1.5"
                                       VerticalOptions="Center"
                                       Margin="10,0,0,0" />
                                <Label Grid.Column="2"
                                       Text="{Binding Gamification.AchievementLabel}"
                                       FontSize="11"
                                       TextColor="{DynamicResource TextMuted}"
                                       VerticalOptions="Center" />
                            </Grid>

                            <!-- Level + Streak -->
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                <HorizontalStackLayout Grid.Column="0" Spacing="10" VerticalOptions="Center">
                                    <Label x:Name="LevelEmojiLabel"
                                           Text="{Binding Gamification.LevelEmoji}"
                                           FontSize="32"
                                           VerticalOptions="Center" />
                                    <VerticalStackLayout Spacing="2" VerticalOptions="Center">
                                        <Label Text="{Binding Gamification.LevelTitle}"
                                               FontSize="16" FontAttributes="Bold"
                                               TextColor="{DynamicResource TextPrimary}" />
                                        <HorizontalStackLayout Spacing="5">
                                            <Label FontSize="12" TextColor="{DynamicResource TextMuted}">
                                                <Label.FormattedText>
                                                    <FormattedString>
                                                        <Span Text="Lvl " />
                                                        <Span Text="{Binding Gamification.Level}"
                                                              TextColor="{Binding Gamification.RangFarbe}"
                                                              FontAttributes="Bold" FontSize="13" />
                                                    </FormattedString>
                                                </Label.FormattedText>
                                            </Label>
                                            <Label Text="·" FontSize="12" TextColor="{DynamicResource TextMuted}" />
                                            <Label Text="{Binding Gamification.ArbeitszeitGesamt}"
                                                   FontSize="12" TextColor="{DynamicResource TextMuted}" />
                                        </HorizontalStackLayout>
                                    </VerticalStackLayout>
                                </HorizontalStackLayout>

                                <!-- Streak-Box -->
                                <Border Grid.Column="1"
                                        BackgroundColor="{DynamicResource SurfaceColor}"
                                        Stroke="{DynamicResource BorderColor}"
                                        StrokeThickness="1"
                                        StrokeShape="RoundRectangle 14"
                                        Padding="14,8"
                                        VerticalOptions="Center">
                                    <VerticalStackLayout Spacing="1" HorizontalOptions="Center">
                                        <Label Text="{Binding Gamification.StreakFlame}"
                                               FontSize="20" HorizontalOptions="Center" />
                                        <Label Text="{Binding Gamification.Streak}"
                                               FontSize="19" FontAttributes="Bold"
                                               TextColor="{StaticResource WarningColor}"
                                               HorizontalOptions="Center" />
                                        <Label Text="Wochen" FontSize="10"
                                               TextColor="{DynamicResource TextMuted}"
                                               HorizontalOptions="Center" />
                                        <Label Text="{Binding Gamification.BesterStreakLabel}"
                                               FontSize="9"
                                               TextColor="{DynamicResource TextMuted}"
                                               HorizontalOptions="Center" />
                                    </VerticalStackLayout>
                                </Border>
                            </Grid>

                            <!-- XP-Balken -->
                            <VerticalStackLayout Spacing="5">
                                <Grid ColumnDefinitions="*,Auto">
                                    <Label Grid.Column="0" FontSize="12"
                                           TextColor="{DynamicResource TextSecondary}">
                                        <Label.FormattedText>
                                            <FormattedString>
                                                <Span Text="{Binding Gamification.XPInLevel, StringFormat='{0:N0}'}"
                                                      TextColor="{Binding Gamification.ProgressColor}"
                                                      FontAttributes="Bold" FontSize="12" />
                                                <Span Text=" / "
                                                      TextColor="{DynamicResource TextMuted}" FontSize="12" />
                                                <Span Text="{Binding Gamification.XPForNextLevel, StringFormat='{0:N0}'}"
                                                      TextColor="{DynamicResource TextMuted}" FontSize="12" />
                                                <Span Text=" XP"
                                                      TextColor="{DynamicResource TextMuted}" FontSize="12" />
                                            </FormattedString>
                                        </Label.FormattedText>
                                    </Label>
                                    <Label Grid.Column="1"
                                           Text="{Binding Gamification.TotalXPLabel}"
                                           FontSize="11" TextColor="{DynamicResource TextMuted}"
                                           VerticalOptions="Center" />
                                </Grid>
                                <ProgressBar x:Name="XpProgressBar"
                                             Progress="{Binding Gamification.LevelProgress}"
                                             ProgressColor="{Binding Gamification.ProgressColor}"
                                             BackgroundColor="{DynamicResource SurfaceColor}"
                                             HeightRequest="10" />
                            </VerticalStackLayout>

                            <!-- Stats-Zeile -->
                            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                                <Border Grid.Column="0"
                                        BackgroundColor="{DynamicResource SurfaceColor}"
                                        Stroke="{DynamicResource BorderColor}" StrokeThickness="1"
                                        StrokeShape="RoundRectangle 10" Padding="8,7">
                                    <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                                        <Label Text="{Binding Gamification.Arbeitstage}"
                                               FontSize="15" FontAttributes="Bold"
                                               TextColor="{DynamicResource TextPrimary}"
                                               HorizontalOptions="Center" />
                                        <Label Text="Tage" FontSize="10"
                                               TextColor="{DynamicResource TextMuted}"
                                               HorizontalOptions="Center" />
                                    </VerticalStackLayout>
                                </Border>
                                <Border Grid.Column="1"
                                        BackgroundColor="{DynamicResource SurfaceColor}"
                                        Stroke="{DynamicResource BorderColor}" StrokeThickness="1"
                                        StrokeShape="RoundRectangle 10" Padding="8,7">
                                    <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                                        <Label Text="{Binding Gamification.AchievementCount}"
                                               FontSize="15" FontAttributes="Bold"
                                               TextColor="{StaticResource WarningColor}"
                                               HorizontalOptions="Center" />
                                        <Label Text="Erfolge" FontSize="10"
                                               TextColor="{DynamicResource TextMuted}"
                                               HorizontalOptions="Center" />
                                    </VerticalStackLayout>
                                </Border>
                                <Border Grid.Column="2"
                                        BackgroundColor="{DynamicResource SurfaceColor}"
                                        Stroke="{DynamicResource BorderColor}" StrokeThickness="1"
                                        StrokeShape="RoundRectangle 10" Padding="8,7">
                                    <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                                        <Label Text="{Binding Gamification.ArbeitszeitGesamt}"
                                               FontSize="15" FontAttributes="Bold"
                                               TextColor="{StaticResource CyanColor}"
                                               HorizontalOptions="Center" />
                                        <Label Text="Gesamt" FontSize="10"
                                               TextColor="{DynamicResource TextMuted}"
                                               HorizontalOptions="Center" />
                                    </VerticalStackLayout>
                                </Border>
                            </Grid>

                            <!-- Achievements -->
                            <CollectionView ItemsSource="{Binding Gamification.Achievements}"
                                            HeightRequest="52">
                                <CollectionView.ItemsLayout>
                                    <LinearItemsLayout Orientation="Horizontal" ItemSpacing="6" />
                                </CollectionView.ItemsLayout>
                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="svc:Achievement">
                                        <Border BackgroundColor="{DynamicResource SurfaceColor}"
                                                Stroke="{DynamicResource BorderColor}"
                                                StrokeThickness="1"
                                                StrokeShape="RoundRectangle 10"
                                                Padding="10,6"
                                                Opacity="{Binding Erreicht, Converter={StaticResource BoolToOpacityConverter}}">
                                            <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                                                <Label Text="{Binding Emoji}"
                                                       FontSize="16" HorizontalOptions="Center" />
                                                <Label Text="{Binding Titel}"
                                                       FontSize="8"
                                                       TextColor="{DynamicResource TextMuted}"
                                                       HorizontalOptions="Center"
                                                       LineBreakMode="TailTruncation"
                                                       MaximumWidthRequest="60" />
                                            </VerticalStackLayout>
                                        </Border>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>

                        </VerticalStackLayout>
                    </Border>

                    <!-- ── Level-Up / Achievement Banner ─────────────────── -->
                    <Border x:Name="LevelUpBanner"
                            Margin="16,8,16,0"
                            BackgroundColor="#1A3580"
                            Stroke="{StaticResource Primary}"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 14"
                            Padding="16,12"
                            IsVisible="False"
                            Opacity="0">
                        <Label x:Name="LevelUpLabel"
                               Text="🎉 Level Up!"
                               FontSize="16" FontAttributes="Bold"
                               TextColor="{DynamicResource TextPrimary}"
                               HorizontalOptions="Center" />
                    </Border>

                    <!-- ── Letzte Einträge ─────────────────────────────── -->
                    <VerticalStackLayout Padding="16,14,16,32" Spacing="8">

                        <Grid ColumnDefinitions="*,Auto" Margin="2,0,2,4">
                            <Label Grid.Column="0"
                                   Text="Zuletzt"
                                   FontSize="17" FontAttributes="Bold"
                                   TextColor="{DynamicResource TextPrimary}" />
                            <Label Grid.Column="1"
                                   Text="{Binding TodayCount, StringFormat='Heute: {0}'}"
                                   FontSize="12"
                                   TextColor="{DynamicResource TextMuted}"
                                   VerticalOptions="Center" />
                        </Grid>

                        <CollectionView ItemsSource="{Binding RecentEntries}">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:TimeEntry">
                                    <Border BackgroundColor="{DynamicResource CardColor}"
                                            Stroke="{DynamicResource BorderColor}"
                                            StrokeThickness="1"
                                            StrokeShape="RoundRectangle 14"
                                            Margin="0,3"
                                            Padding="14,11">
                                        <Grid ColumnDefinitions="8,*,Auto" ColumnSpacing="12">
                                            <Ellipse Grid.Column="0"
                                                     WidthRequest="8" HeightRequest="8"
                                                     Fill="{StaticResource Primary}"
                                                     VerticalOptions="Center" />
                                            <VerticalStackLayout Grid.Column="1" Spacing="2">
                                                <Label Text="{Binding Title}"
                                                       FontSize="13" FontAttributes="Bold"
                                                       TextColor="{DynamicResource TextPrimary}"
                                                       LineBreakMode="TailTruncation" />
                                                <HorizontalStackLayout Spacing="8">
                                                    <Label Text="{Binding StartTimeDisplay}"
                                                           FontSize="11"
                                                           TextColor="{DynamicResource TextMuted}" />
                                                    <Label Text="·"
                                                           FontSize="11"
                                                           TextColor="{DynamicResource TextMuted}" />
                                                    <Label Text="{Binding TimeRangeDisplay}"
                                                           FontSize="11"
                                                           TextColor="{DynamicResource TextMuted}" />
                                                </HorizontalStackLayout>
                                            </VerticalStackLayout>
                                            <Label Grid.Column="2"
                                                   Text="{Binding DurationDisplay}"
                                                   FontSize="13" FontAttributes="Bold"
                                                   TextColor="{StaticResource SuccessColor}"
                                                   VerticalOptions="Center" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                            <CollectionView.EmptyView>
                                <VerticalStackLayout Spacing="8" HorizontalOptions="Center" Margin="0,20">
                                    <Label Text="▶"
                                           FontSize="28"
                                           TextColor="{DynamicResource TextMuted}"
                                           HorizontalOptions="Center" />
                                    <Label Text="Starte deinen ersten Timer"
                                           FontSize="14"
                                           TextColor="{DynamicResource TextMuted}"
                                           HorizontalOptions="Center" />
                                </VerticalStackLayout>
                            </CollectionView.EmptyView>
                        </CollectionView>

                    </VerticalStackLayout>

                </VerticalStackLayout>
            </ScrollView>
        </RefreshView>

    </Grid>

</ContentPage>
