<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:VERA.ViewModels"
             x:Class="VERA.Views.StatistikPage"
             x:DataType="vm:StatistikViewModel"
             BackgroundColor="{StaticResource AppBackground}"
             Title="Statistiken">

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- Header -->
        <Grid Grid.Row="0" Padding="8,48,20,12" ColumnDefinitions="56,*">
            <Button Grid.Column="0" Text="&#9776;" FontSize="22"
                    TextColor="{StaticResource TextPrimary}" BackgroundColor="Transparent"
                    Clicked="OnMenuClicked" VerticalOptions="Center" />
            <VerticalStackLayout Grid.Column="1" Spacing="1" VerticalOptions="Center">
                <Label Text="Statistiken" FontSize="22" FontAttributes="Bold"
                       TextColor="{StaticResource TextPrimary}" />
                <Label Text="{Binding MonatLabel}" FontSize="11" TextColor="{StaticResource TextMuted}" />
            </VerticalStackLayout>
        </Grid>

        <!-- Woche / Monat Umschalter -->
        <Border Grid.Row="1" Margin="16,0,16,12"
                BackgroundColor="{StaticResource CardColor}"
                Stroke="{StaticResource BorderColor}" StrokeThickness="1"
                StrokeShape="RoundRectangle 14" Padding="4">
            <Grid ColumnDefinitions="*,*">
                <Button Grid.Column="0" Text="Diese Woche"
                        Command="{Binding ZeigeWocheCommand}"
                        BackgroundColor="{Binding ZeigeWoche, Converter={StaticResource BoolToCardConverter}}"
                        TextColor="{StaticResource TextPrimary}"
                        FontSize="14" CornerRadius="10" HeightRequest="40" />
                <Button Grid.Column="1" Text="Dieser Monat"
                        Command="{Binding ZeigeMonatCommand}"
                        BackgroundColor="{Binding ZeigeMonat, Converter={StaticResource BoolToCardConverter}}"
                        TextColor="{StaticResource TextPrimary}"
                        FontSize="14" CornerRadius="10" HeightRequest="40" />
            </Grid>
        </Border>

        <ScrollView Grid.Row="2">
            <VerticalStackLayout Padding="16,0,16,28" Spacing="14">

                <!-- ===== WOCHENANSICHT ===== -->
                <VerticalStackLayout IsVisible="{Binding ZeigeWoche}" Spacing="14">

                    <!-- Wochen-Zusammenfassung -->
                    <Border BackgroundColor="{StaticResource CardColor}"
                            Stroke="{StaticResource BorderColor}" StrokeThickness="1"
                            StrokeShape="RoundRectangle 18" Padding="20,18">
                        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                            <VerticalStackLayout Grid.Column="0" Spacing="4">
                                <Label Text="Gearbeitet" FontSize="11" TextColor="{StaticResource TextSecondary}" />
                                <Label Text="{Binding WocheGesamt}" FontSize="20" FontAttributes="Bold"
                                       TextColor="{StaticResource TextPrimary}" />
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1" Spacing="4">
                                <Label Text="Sollzeit" FontSize="11" TextColor="{StaticResource TextSecondary}" />
                                <Label Text="{Binding WocheSoll}" FontSize="20" FontAttributes="Bold"
                                       TextColor="{StaticResource TextMuted}" />
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="2" Spacing="4">
                                <Label Text="Puffer" FontSize="11" TextColor="{StaticResource TextSecondary}" />
                                <Label Text="{Binding WochePuffer}" FontSize="20" FontAttributes="Bold"
                                       TextColor="{Binding PufferFarbe}" />
                            </VerticalStackLayout>
                        </Grid>
                    </Border>

                    <!-- Tag-Kacheln -->
                    <Label Text="Tag&#252;bersicht" FontSize="17" FontAttributes="Bold"
                           TextColor="{StaticResource TextPrimary}" Margin="4,0,0,0" />

                    <CollectionView ItemsSource="{Binding WochenDaten}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="vm:TagData">
                                <Border BackgroundColor="{StaticResource CardColor}"
                                        Stroke="{StaticResource BorderColor}" StrokeThickness="1"
                                        StrokeShape="RoundRectangle 14" Margin="0,4" Padding="18,14">
                                    <Grid ColumnDefinitions="36,*,Auto" ColumnSpacing="12">
                                        <Label Grid.Column="0" Text="{Binding Name}"
                                               FontSize="15" FontAttributes="Bold"
                                               TextColor="{StaticResource TextPrimary}"
                                               VerticalOptions="Center" />
                                        <VerticalStackLayout Grid.Column="1" Spacing="6" VerticalOptions="Center">
                                            <ProgressBar Progress="{Binding Fortschritt}"
                                                         ProgressColor="{Binding FortschrittFarbe}"
                                                         BackgroundColor="{StaticResource SurfaceColor}"
                                                         HeightRequest="7" />
                                            <Label Text="{Binding GearbeiteteAnzeige}" FontSize="12"
                                                   TextColor="{StaticResource TextMuted}" />
                                        </VerticalStackLayout>
                                        <Border Grid.Column="2"
                                                BackgroundColor="{StaticResource SurfaceColor}"
                                                Stroke="{StaticResource Primary}" StrokeThickness="1"
                                                StrokeShape="RoundRectangle 8" Padding="8,4"
                                                VerticalOptions="Center" IsVisible="{Binding IstHeute}">
                                            <Label Text="Heute" FontSize="11"
                                                   TextColor="{StaticResource Primary}" FontAttributes="Bold" />
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>

                <!-- ===== MONATSANSICHT ===== -->
                <VerticalStackLayout IsVisible="{Binding ZeigeMonat}" Spacing="14">

                    <!-- Monats-Zusammenfassung -->
                    <Border BackgroundColor="{StaticResource CardColor}"
                            Stroke="{StaticResource BorderColor}" StrokeThickness="1"
                            StrokeShape="RoundRectangle 18" Padding="20,18">
                        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                            <VerticalStackLayout Grid.Column="0" Spacing="4">
                                <Label Text="Gearbeitet" FontSize="11" TextColor="{StaticResource TextSecondary}" />
                                <Label Text="{Binding MonatGesamt}" FontSize="20" FontAttributes="Bold"
                                       TextColor="{StaticResource TextPrimary}" />
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1" Spacing="4">
                                <Label Text="Bis heute" FontSize="11" TextColor="{StaticResource TextSecondary}" />
                                <Label Text="{Binding MonatSoll}" FontSize="20" FontAttributes="Bold"
                                       TextColor="{StaticResource TextMuted}" />
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="2" Spacing="4">
                                <Label Text="Puffer" FontSize="11" TextColor="{StaticResource TextSecondary}" />
                                <Label Text="{Binding MonatPuffer}" FontSize="20" FontAttributes="Bold"
                                       TextColor="{Binding MonatPufferFarbe}" />
                            </VerticalStackLayout>
                        </Grid>
                    </Border>

                    <!-- Kalender -->
                    <Border BackgroundColor="{StaticResource CardColor}"
                            Stroke="{StaticResource BorderColor}" StrokeThickness="1"
                            StrokeShape="RoundRectangle 18" Padding="14,16">
                        <VerticalStackLayout Spacing="10">

                            <!-- Monat Navigation -->
                            <Grid ColumnDefinitions="Auto,*,Auto">
                                <Button Grid.Column="0"
                                        Text="◀" FontSize="16"
                                        TextColor="{StaticResource TextSecondary}"
                                        BackgroundColor="Transparent"
                                        Command="{Binding VorigerMonatCommand}"
                                        WidthRequest="40" HeightRequest="36" Padding="0" />
                                <Label Grid.Column="1"
                                       Text="{Binding MonatLabel}"
                                       FontSize="15" FontAttributes="Bold"
                                       TextColor="{StaticResource TextPrimary}"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center" />
                                <Button Grid.Column="2"
                                        Text="▶" FontSize="16"
                                        TextColor="{StaticResource TextSecondary}"
                                        BackgroundColor="Transparent"
                                        Command="{Binding NaechsterMonatCommand}"
                                        WidthRequest="40" HeightRequest="36" Padding="0" />
                            </Grid>

                            <!-- Wochentag-Header -->
                            <Grid ColumnDefinitions="*,*,*,*,*,*,*" ColumnSpacing="3">
                                <Label Grid.Column="0" Text="Mo" FontSize="11" FontAttributes="Bold"
                                       TextColor="{StaticResource TextMuted}" HorizontalOptions="Center"/>
                                <Label Grid.Column="1" Text="Di" FontSize="11" FontAttributes="Bold"
                                       TextColor="{StaticResource TextMuted}" HorizontalOptions="Center"/>
                                <Label Grid.Column="2" Text="Mi" FontSize="11" FontAttributes="Bold"
                                       TextColor="{StaticResource TextMuted}" HorizontalOptions="Center"/>
                                <Label Grid.Column="3" Text="Do" FontSize="11" FontAttributes="Bold"
                                       TextColor="{StaticResource TextMuted}" HorizontalOptions="Center"/>
                                <Label Grid.Column="4" Text="Fr" FontSize="11" FontAttributes="Bold"
                                       TextColor="{StaticResource TextMuted}" HorizontalOptions="Center"/>
                                <Label Grid.Column="5" Text="Sa" FontSize="11" FontAttributes="Bold"
                                       TextColor="{StaticResource BorderColor}" HorizontalOptions="Center"/>
                                <Label Grid.Column="6" Text="So" FontSize="11" FontAttributes="Bold"
                                       TextColor="{StaticResource BorderColor}" HorizontalOptions="Center"/>
                            </Grid>

                            <!-- Kalender-Grid (7 Spalten, dynamische Zeilen via CollectionView) -->
                            <CollectionView ItemsSource="{Binding KalenderTage}"
                                            ItemsLayout="VerticalGrid"
                                            HeightRequest="260">
                                <CollectionView.ItemsLayout>
                                    <GridItemsLayout Orientation="Vertical" Span="7" HorizontalItemSpacing="3" VerticalItemSpacing="3" />
                                </CollectionView.ItemsLayout>
                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="vm:KalenderTagData">
                                        <Border BackgroundColor="{Binding HintergrundFarbe}"
                                                Stroke="{Binding RandFarbe}"
                                                StrokeThickness="1.5"
                                                StrokeShape="RoundRectangle 7"
                                                HeightRequest="44">
                                            <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="1">
                                                <Label Text="{Binding TagText}"
                                                       FontSize="13" FontAttributes="Bold"
                                                       TextColor="{Binding TextFarbe}"
                                                       HorizontalOptions="Center" />
                                                <Label Text="{Binding IndikatorEmoji}"
                                                       FontSize="9"
                                                       TextColor="{Binding IndikatorFarbe}"
                                                       HorizontalOptions="Center" />
                                            </VerticalStackLayout>
                                        </Border>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>

                            <!-- Legende -->
                            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="6" Margin="0,4,0,0">
                                <HorizontalStackLayout Grid.Column="0" Spacing="5" HorizontalOptions="Center">
                                    <BoxView WidthRequest="10" HeightRequest="10" CornerRadius="3"
                                             Color="#0D2B22" VerticalOptions="Center"/>
                                    <Label Text="Soll ✓" FontSize="10" TextColor="{StaticResource TextMuted}" VerticalOptions="Center"/>
                                </HorizontalStackLayout>
                                <HorizontalStackLayout Grid.Column="1" Spacing="5" HorizontalOptions="Center">
                                    <BoxView WidthRequest="10" HeightRequest="10" CornerRadius="3"
                                             Color="#2A1555" VerticalOptions="Center"/>
                                    <Label Text="Sondertag" FontSize="10" TextColor="{StaticResource TextMuted}" VerticalOptions="Center"/>
                                </HorizontalStackLayout>
                                <HorizontalStackLayout Grid.Column="2" Spacing="5" HorizontalOptions="Center">
                                    <BoxView WidthRequest="10" HeightRequest="10" CornerRadius="3"
                                             Color="#1A3580" VerticalOptions="Center"/>
                                    <Label Text="Heute" FontSize="10" TextColor="{StaticResource TextMuted}" VerticalOptions="Center"/>
                                </HorizontalStackLayout>
                            </Grid>

                        </VerticalStackLayout>
                    </Border>

                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>