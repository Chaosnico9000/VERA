<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="VERA.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:VERA.Views"
    FlyoutBehavior="Flyout"
    FlyoutBackgroundColor="{StaticResource SurfaceColor}"
    Shell.BackgroundColor="{StaticResource SurfaceColor}"
    Shell.ForegroundColor="{StaticResource Primary}"
    Shell.TitleColor="{StaticResource TextPrimary}"
    Shell.UnselectedColor="{StaticResource TextMuted}"
    Shell.NavBarIsVisible="False">

    <!-- Flyout Header mit Logo -->
    <Shell.FlyoutHeader>
        <Grid BackgroundColor="{StaticResource CardColor}"
              Padding="0,0,0,0">
            <!-- Logo-Bild als Header-Banner -->
            <Image Source="vera_logo.png"
                   HeightRequest="160"
                   Aspect="AspectFill" />
            <!-- Gradient-Overlay für Lesbarkeit -->
            <BoxView BackgroundColor="#CC080C1E"
                     VerticalOptions="End"
                     HeightRequest="80" />
            <!-- VERA Text über dem Logo -->
            <VerticalStackLayout VerticalOptions="End"
                                 Padding="20,0,20,16"
                                 Spacing="1">
                <Label Text="VERA"
                       FontSize="26"
                       FontAttributes="Bold"
                       TextColor="{StaticResource TextPrimary}" />
                <Label Text="Zeiterfassungs-Assistent"
                       FontSize="11"
                       TextColor="{StaticResource TextSecondary}" />
            </VerticalStackLayout>
        </Grid>
    </Shell.FlyoutHeader>

    <!-- Item-Vorlage -->
    <Shell.ItemTemplate>
        <DataTemplate>
            <Grid HeightRequest="56" Padding="20,0" BackgroundColor="Transparent">
                <VisualStateManager.VisualStateGroups>
                    <VisualStateGroupList>
                        <VisualStateGroup x:Name="CommonStates">
                            <VisualState x:Name="Normal">
                                <VisualState.Setters>
                                    <Setter Property="Grid.BackgroundColor" Value="Transparent" />
                                </VisualState.Setters>
                            </VisualState>
                            <VisualState x:Name="Selected">
                                <VisualState.Setters>
                                    <Setter Property="Grid.BackgroundColor" Value="{StaticResource CardElevated}" />
                                </VisualState.Setters>
                            </VisualState>
                        </VisualStateGroup>
                    </VisualStateGroupList>
                </VisualStateManager.VisualStateGroups>
                <Label Text="{Binding Title}"
                       FontSize="16"
                       TextColor="{StaticResource TextPrimary}"
                       FontFamily="OpenSansRegular"
                       VerticalOptions="Center"
                       Margin="4,0" />
            </Grid>
        </DataTemplate>
    </Shell.ItemTemplate>

    <!-- Flyout Footer -->
    <Shell.FlyoutFooter>
        <VerticalStackLayout Padding="20,16,20,24" Spacing="2">
            <BoxView HeightRequest="1"
                     BackgroundColor="{StaticResource BorderColor}"
                     Margin="0,0,0,12" />
            <Label Text="VERA · Vertrauensarbeitszeit"
                   FontSize="11"
                   TextColor="{StaticResource TextMuted}" />
        </VerticalStackLayout>
    </Shell.FlyoutFooter>

    <!-- Navigation -->
    <FlyoutItem Title="⏱  Zeittracker" Route="ZeitTrackerPage">
        <ShellContent ContentTemplate="{DataTemplate views:ZeitTrackerPage}" />
    </FlyoutItem>

    <FlyoutItem Title="📊  Statistiken" Route="StatistikPage">
        <ShellContent ContentTemplate="{DataTemplate views:StatistikPage}" />
    </FlyoutItem>

    <FlyoutItem Title="📋  Verlauf" Route="HistoryPage">
        <ShellContent ContentTemplate="{DataTemplate views:HistoryPage}" />
    </FlyoutItem>

    <FlyoutItem Title="🏆  Leveling" Route="LevelingPage">
        <ShellContent ContentTemplate="{DataTemplate views:LevelingPage}" />
    </FlyoutItem>

    <FlyoutItem Title="⚙️  Einstellungen" Route="EinstellungenPage">
        <ShellContent ContentTemplate="{DataTemplate views:EinstellungenPage}" />
    </FlyoutItem>

</Shell>
