<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VERA.Views.RegisterPage"
             BackgroundColor="{StaticResource AppBackground}"
             Shell.NavBarIsVisible="False"
             NavigationPage.HasNavigationBar="False">

    <Grid RowDefinitions="*,Auto,*">
        <ScrollView Grid.Row="1">
            <VerticalStackLayout HorizontalOptions="Center"
                                 MaximumWidthRequest="400"
                                 Spacing="0"
                                 Padding="32,0">

                <!-- Logo -->
                <VerticalStackLayout HorizontalOptions="Center" Spacing="8" Margin="0,0,0,36">
                    <Border BackgroundColor="{StaticResource CardColor}"
                            Stroke="{StaticResource Primary}"
                            StrokeThickness="2"
                            StrokeShape="RoundRectangle 28"
                            WidthRequest="88" HeightRequest="88"
                            HorizontalOptions="Center">
                        <Label Text="V" FontSize="44" FontAttributes="Bold"
                               TextColor="{StaticResource Primary}"
                               HorizontalOptions="Center" VerticalOptions="Center" />
                    </Border>
                    <Label Text="VERA" FontSize="28" FontAttributes="Bold"
                           TextColor="{StaticResource TextPrimary}"
                           HorizontalOptions="Center" CharacterSpacing="4" />
                    <Label Text="Account erstellen"
                           FontSize="13" TextColor="{StaticResource TextMuted}"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>

                <!-- Formular -->
                <VerticalStackLayout Spacing="14">

                    <!-- Benutzername -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="BENUTZERNAME"
                               FontSize="11" FontAttributes="Bold"
                               TextColor="{StaticResource TextMuted}"
                               CharacterSpacing="1.2" />
                        <Border BackgroundColor="{StaticResource CardColor}"
                                Stroke="{StaticResource BorderColor}" StrokeThickness="1"
                                StrokeShape="RoundRectangle 14" Padding="16,0">
                            <Entry x:Name="UsernameEntry"
                                   Placeholder="Dein Name"
                                   PlaceholderColor="{StaticResource TextMuted}"
                                   TextColor="{StaticResource TextPrimary}"
                                   FontSize="15"
                                   HeightRequest="50"
                                   BackgroundColor="Transparent"
                                   ReturnType="Next"
                                   Keyboard="Text"
                                   MaxLength="30" />
                        </Border>
                    </VerticalStackLayout>

                    <!-- Passwort -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="PASSWORT"
                               FontSize="11" FontAttributes="Bold"
                               TextColor="{StaticResource TextMuted}"
                               CharacterSpacing="1.2" />
                        <Border BackgroundColor="{StaticResource CardColor}"
                                Stroke="{StaticResource BorderColor}" StrokeThickness="1"
                                StrokeShape="RoundRectangle 14" Padding="16,0">
                            <Entry x:Name="PasswordEntry"
                                   Placeholder="Mind. 8 Zeichen"
                                   PlaceholderColor="{StaticResource TextMuted}"
                                   TextColor="{StaticResource TextPrimary}"
                                   FontSize="15"
                                   HeightRequest="50"
                                   BackgroundColor="Transparent"
                                   IsPassword="True"
                                   ReturnType="Next"
                                   TextChanged="OnPasswordChanged" />
                        </Border>
                        <!-- Stärke-Anzeige -->
                        <ProgressBar x:Name="StrengthBar"
                                     Progress="0"
                                     ProgressColor="{StaticResource Accent}"
                                     BackgroundColor="{StaticResource SurfaceColor}"
                                     HeightRequest="4" />
                        <Label x:Name="StrengthLabel"
                               Text=""
                               FontSize="11"
                               TextColor="{StaticResource TextMuted}" />
                    </VerticalStackLayout>

                    <!-- Passwort bestätigen -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="PASSWORT BESTÄTIGEN"
                               FontSize="11" FontAttributes="Bold"
                               TextColor="{StaticResource TextMuted}"
                               CharacterSpacing="1.2" />
                        <Border BackgroundColor="{StaticResource CardColor}"
                                Stroke="{StaticResource BorderColor}" StrokeThickness="1"
                                StrokeShape="RoundRectangle 14" Padding="16,0">
                            <Entry x:Name="ConfirmEntry"
                                   Placeholder="Passwort wiederholen"
                                   PlaceholderColor="{StaticResource TextMuted}"
                                   TextColor="{StaticResource TextPrimary}"
                                   FontSize="15"
                                   HeightRequest="50"
                                   BackgroundColor="Transparent"
                                   IsPassword="True"
                                   ReturnType="Done"
                                   ReturnCommand="{x:Null}" />
                        </Border>
                    </VerticalStackLayout>

                    <!-- Fehler -->
                    <Label x:Name="ErrorLabel"
                           Text=""
                           FontSize="13"
                           TextColor="{StaticResource Accent}"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center"
                           IsVisible="False" />

                    <!-- Registrieren-Button -->
                    <Button x:Name="RegisterButton"
                            Text="🔐  Account erstellen"
                            Clicked="OnRegisterClicked"
                            BackgroundColor="{StaticResource Primary}"
                            TextColor="{StaticResource TextPrimary}"
                            FontSize="16" FontAttributes="Bold"
                            HeightRequest="54" CornerRadius="16"
                            HorizontalOptions="Fill"
                            Margin="0,8,0,0" />

                    <!-- Info -->
                    <Label Text="Dein Account wird ausschließlich lokal auf diesem Gerät gespeichert. Es werden keine Daten übertragen."
                           FontSize="11"
                           TextColor="{StaticResource TextMuted}"
                           HorizontalTextAlignment="Center"
                           Margin="0,8,0,32" />

                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
