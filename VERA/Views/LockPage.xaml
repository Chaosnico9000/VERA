<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="VERA.Views.LockPage"
    BackgroundColor="{StaticResource AppBackground}"
    Shell.NavBarIsVisible="False"
    Shell.TabBarIsVisible="False"
    NavigationPage.HasNavigationBar="False">

    <Grid RowDefinitions="*,Auto,*">

        <VerticalStackLayout
            Grid.Row="1"
            HorizontalOptions="Center"
            Spacing="28"
            Padding="40,0">

            <VerticalStackLayout HorizontalOptions="Center" Spacing="8">
                <Border
                    BackgroundColor="{StaticResource CardColor}"
                    Stroke="{StaticResource Primary}"
                    StrokeThickness="2"
                    StrokeShape="RoundRectangle 28"
                    WidthRequest="88"
                    HeightRequest="88"
                    HorizontalOptions="Center">
                    <Label
                        Text="V"
                        FontSize="44"
                        FontAttributes="Bold"
                        TextColor="{StaticResource Primary}"
                        HorizontalOptions="Center"
                        VerticalOptions="Center" />
                </Border>
                <Label
                    Text="VERA"
                    FontSize="28"
                    FontAttributes="Bold"
                    TextColor="{StaticResource TextPrimary}"
                    HorizontalOptions="Center"
                    CharacterSpacing="4" />
                <Label
                    Text="Zeiterfassung"
                    FontSize="13"
                    TextColor="{StaticResource TextMuted}"
                    HorizontalOptions="Center" />
            </VerticalStackLayout>

            <Label
                x:Name="StatusLabel"
                Text="Entsperre mit deinem Fingerabdruck,&#10;Gesicht oder Geräte-PIN"
                FontSize="14"
                TextColor="{StaticResource TextSecondary}"
                HorizontalOptions="Center"
                HorizontalTextAlignment="Center"
                LineHeight="1.4" />

            <Button
                x:Name="UnlockButton"
                Text="🔐  Entsperren"
                Clicked="OnUnlockClicked"
                BackgroundColor="{StaticResource Primary}"
                TextColor="{StaticResource TextPrimary}"
                FontSize="16"
                FontAttributes="Bold"
                HeightRequest="54"
                CornerRadius="16"
                HorizontalOptions="Fill" />

            <Label
                x:Name="ErrorLabel"
                Text=""
                FontSize="13"
                TextColor="{StaticResource Accent}"
                HorizontalOptions="Center"
                HorizontalTextAlignment="Center"
                IsVisible="False" />

        </VerticalStackLayout>

    </Grid>

</ContentPage>
