<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:VERA.ViewModels"
             x:Class="VERA.Views.EinstellungenPage"
             x:DataType="vm:EinstellungenViewModel"
             BackgroundColor="{StaticResource AppBackground}"
             Title="Einstellungen">

    <ScrollView>
        <VerticalStackLayout Spacing="0">

            <!-- Header -->
            <Grid Padding="8,48,20,16" ColumnDefinitions="56,*">
                <Button Grid.Column="0" Text="&#9776;" FontSize="22"
                        TextColor="{StaticResource TextPrimary}" BackgroundColor="Transparent"
                        Clicked="OnMenuClicked" VerticalOptions="Center" />
                <VerticalStackLayout Grid.Column="1" Spacing="1" VerticalOptions="Center">
                    <Label Text="Einstellungen" FontSize="22" FontAttributes="Bold"
                           TextColor="{StaticResource TextPrimary}" />
                    <Label Text="Konfiguration" FontSize="11" TextColor="{StaticResource TextMuted}" />
                </VerticalStackLayout>
            </Grid>

            <!-- Sektion: Arbeitszeit -->
            <Label Text="ARBEITSZEIT" FontSize="11" FontAttributes="Bold"
                   TextColor="{StaticResource TextMuted}" Margin="20,8,20,8" CharacterSpacing="1.5" />

            <Border Margin="16,0" BackgroundColor="{StaticResource CardColor}"
                    Stroke="{StaticResource BorderColor}" StrokeThickness="1"
                    StrokeShape="RoundRectangle 16" Padding="20,18">
                <VerticalStackLayout Spacing="16">

                    <Grid ColumnDefinitions="*,Auto">
                        <VerticalStackLayout Grid.Column="0" Spacing="3">
                            <Label Text="T&#228;gliche Sollzeit" FontSize="16" TextColor="{StaticResource TextPrimary}" />
                            <Label Text="Deine Vertrauensarbeitszeit pro Tag" FontSize="12"
                                   TextColor="{StaticResource TextMuted}" />
                        </VerticalStackLayout>
                        <HorizontalStackLayout Grid.Column="1" Spacing="0" VerticalOptions="Center">
                            <Button Text="&#8722;" Command="{Binding VerringernCommand}"
                                    BackgroundColor="{StaticResource SurfaceColor}"
                                    TextColor="{StaticResource TextPrimary}"
                                    FontSize="20" WidthRequest="42" HeightRequest="42"
                                    CornerRadius="10" Padding="0" Margin="0,0,6,0" />
                            <Border BackgroundColor="{StaticResource SurfaceColor}"
                                    Stroke="{StaticResource BorderColor}" StrokeThickness="1"
                                    StrokeShape="RoundRectangle 10"
                                    Padding="12,0" WidthRequest="60" HeightRequest="42">
                                <Label Text="{Binding SollzeitAnzeige}" FontSize="16" FontAttributes="Bold"
                                       TextColor="{StaticResource Primary}"
                                       HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>
                            <Button Text="+" Command="{Binding ErhoehenCommand}"
                                    BackgroundColor="{StaticResource SurfaceColor}"
                                    TextColor="{StaticResource TextPrimary}"
                                    FontSize="20" WidthRequest="42" HeightRequest="42"
                                    CornerRadius="10" Padding="0" Margin="6,0,0,0" />
                        </HorizontalStackLayout>
                    </Grid>

                    <BoxView HeightRequest="1" BackgroundColor="{StaticResource BorderColor}" />

                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0" Text="Wochenziel (5 Tage)" FontSize="14"
                               TextColor="{StaticResource TextSecondary}" VerticalOptions="Center" />
                        <Label Grid.Column="1" Text="{Binding WochenzielAnzeige}" FontSize="16"
                               FontAttributes="Bold" TextColor="{StaticResource SuccessColor}"
                               VerticalOptions="Center" />
                    </Grid>

                </VerticalStackLayout>
            </Border>

            <!-- Sektion: Arbeitsbeginn -->
            <Label Text="ARBEITSBEGINN" FontSize="11" FontAttributes="Bold"
                   TextColor="{StaticResource TextMuted}" Margin="20,24,20,8" CharacterSpacing="1.5" />

            <Border Margin="16,0" BackgroundColor="{StaticResource CardColor}"
                    Stroke="{StaticResource BorderColor}" StrokeThickness="1"
                    StrokeShape="RoundRectangle 16" Padding="20,18">
                <Grid ColumnDefinitions="*,Auto">
                    <VerticalStackLayout Grid.Column="0" Spacing="3">
                        <Label Text="Erster Arbeitstag" FontSize="16" TextColor="{StaticResource TextPrimary}" />
                        <Label Text="Ab wann die Gesamtübersicht zählt" FontSize="12"
                               TextColor="{StaticResource TextMuted}" />
                    </VerticalStackLayout>
                    <DatePicker Grid.Column="1"
                                Date="{Binding ErsterArbeitstag}"
                                Format="dd.MM.yyyy"
                                TextColor="{StaticResource Primary}"
                                BackgroundColor="Transparent"
                                FontSize="15"
                                VerticalOptions="Center" />
                </Grid>
            </Border>

            <!-- Sektion: Benachrichtigungen -->
            <Label Text="BENACHRICHTIGUNGEN" FontSize="11" FontAttributes="Bold"
                   TextColor="{StaticResource TextMuted}" Margin="20,24,20,8" CharacterSpacing="1.5" />

            <Border Margin="16,0" BackgroundColor="{StaticResource CardColor}"
                    Stroke="{StaticResource BorderColor}" StrokeThickness="1"
                    StrokeShape="RoundRectangle 16" Padding="20,6">
                <VerticalStackLayout Spacing="0">

                    <!-- Toggle -->
                    <Grid ColumnDefinitions="*,Auto" Padding="0,12">
                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                            <Label Text="Erinnerung aktivieren" FontSize="16"
                                   TextColor="{StaticResource TextPrimary}" />
                            <Label Text="Dagliche Erinnerung zum Timer starten"
                                   FontSize="12" TextColor="{StaticResource TextMuted}" />
                        </VerticalStackLayout>
                        <Switch Grid.Column="1" IsToggled="{Binding ErinnerungAktiv}"
                                OnColor="{StaticResource Primary}"
                                ThumbColor="{StaticResource TextPrimary}"
                                VerticalOptions="Center" />
                    </Grid>

                    <BoxView HeightRequest="1" BackgroundColor="{StaticResource BorderColor}"
                             IsVisible="{Binding ErinnerungAktiv}" />

                    <!-- Uhrzeit -->
                    <Grid ColumnDefinitions="*,Auto" Padding="0,12"
                          IsVisible="{Binding ErinnerungAktiv}">
                        <Label Grid.Column="0" Text="Uhrzeit" FontSize="15"
                               TextColor="{StaticResource TextSecondary}" VerticalOptions="Center" />
                        <TimePicker Grid.Column="1" Time="{Binding ErinnerungsZeit}"
                                    TextColor="{StaticResource TextPrimary}"
                                    BackgroundColor="Transparent"
                                    Format="HH:mm" FontSize="15" />
                    </Grid>

                    <BoxView HeightRequest="1" BackgroundColor="{StaticResource BorderColor}" />

                    <!-- Test-Button -->
                    <Button Text="&#128276; Testnachricht senden"
                            Command="{Binding TestNachrichtCommand}"
                            BackgroundColor="Transparent"
                            TextColor="{StaticResource CyanColor}"
                            FontSize="15" HeightRequest="52" />

                </VerticalStackLayout>
            </Border>

            <!-- Sektion: Account -->
            <Label Text="ACCOUNT" FontSize="11" FontAttributes="Bold"
                   TextColor="{StaticResource TextMuted}" Margin="20,24,20,8" CharacterSpacing="1.5" />

            <Border Margin="16,0" BackgroundColor="{StaticResource CardColor}"
                    Stroke="{StaticResource BorderColor}" StrokeThickness="1"
                    StrokeShape="RoundRectangle 16" Padding="4">
                <VerticalStackLayout Spacing="0">
                    <Button Text="🔑  Passwort ändern"
                            Clicked="OnChangePasswordClicked"
                            BackgroundColor="Transparent"
                            TextColor="{StaticResource TextPrimary}"
                            FontSize="15" HeightRequest="52" />
                </VerticalStackLayout>
            </Border>

            <!-- Sektion: Daten -->
            <Label Text="DATEN" FontSize="11" FontAttributes="Bold"
                   TextColor="{StaticResource TextMuted}" Margin="20,24,20,8" CharacterSpacing="1.5" />

            <Border Margin="16,0,16,36" BackgroundColor="{StaticResource CardColor}"
                    Stroke="{StaticResource BorderColor}" StrokeThickness="1"
                    StrokeShape="RoundRectangle 16" Padding="4">
                <Button Text="&#128465;  Alle Eintr&#228;ge l&#246;schen"
                        Command="{Binding ResetCommand}"
                        BackgroundColor="Transparent"
                        TextColor="{StaticResource Accent}"
                        FontSize="15" HeightRequest="52" />
            </Border>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>