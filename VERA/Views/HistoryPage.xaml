<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:VERA.ViewModels"
             xmlns:models="clr-namespace:VERA.Models"
             x:Class="VERA.Views.HistoryPage"
             x:DataType="vm:HistoryViewModel"
             BackgroundColor="{StaticResource AppBackground}"
             Title="Verlauf">

    <!-- Outer Grid: List + FAB overlay -->
    <Grid>

        <Grid RowDefinitions="Auto,*">

            <!-- Header -->
            <Grid Grid.Row="0" Padding="24,48,24,16" ColumnDefinitions="*,Auto">
                <VerticalStackLayout Grid.Column="0" Spacing="2">
                    <Label Text="Verlauf"
                           FontSize="28"
                           FontAttributes="Bold"
                           TextColor="{StaticResource TextPrimary}" />
                    <Label FontSize="13" TextColor="{StaticResource TextSecondary}">
                        <Label.FormattedText>
                            <FormattedString>
                                <Span Text="Diese Woche: " TextColor="{StaticResource TextMuted}" FontSize="13"/>
                                <Span Text="{Binding WeekTotal}" TextColor="{StaticResource SuccessColor}" FontAttributes="Bold" FontSize="13"/>
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>
                </VerticalStackLayout>
            </Grid>

            <!-- Grouped Entry List -->
            <CollectionView Grid.Row="1"
                            ItemsSource="{Binding GroupedEntries}"
                            IsGrouped="True"
                            Margin="16,0,16,88">

                <CollectionView.GroupHeaderTemplate>
                    <DataTemplate x:DataType="vm:DayGroup">
                        <Grid ColumnDefinitions="*,Auto,Auto" Padding="4,18,4,6" ColumnSpacing="8">
                            <Label Grid.Column="0"
                                   Text="{Binding DayLabel}"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource TextSecondary}" />
                            <Label Grid.Column="1"
                                   Text="{Binding DeltaText}"
                                   FontSize="12"
                                   FontAttributes="Bold"
                                   TextColor="{Binding DeltaColor}"
                                   VerticalOptions="Center" />
                            <Label Grid.Column="2"
                                   Text="{Binding TotalTime}"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource SuccessColor}" />
                        </Grid>
                    </DataTemplate>
                </CollectionView.GroupHeaderTemplate>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:TimeEntry">
                        <Border BackgroundColor="{StaticResource CardColor}"
                                Stroke="{StaticResource BorderColor}"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 14"
                                Margin="0,3"
                                Padding="14,12">
                            <Grid ColumnDefinitions="6,*,Auto" ColumnSpacing="12">

                                <!-- Farbiger Indikatorstreifen -->
                                <BoxView Grid.Column="0"
                                         WidthRequest="4"
                                         CornerRadius="2"
                                         VerticalOptions="Fill">
                                    <BoxView.Triggers>
                                        <DataTrigger TargetType="BoxView" Binding="{Binding Type}" Value="Arbeit">
                                            <Setter Property="Color" Value="{StaticResource Primary}" />
                                        </DataTrigger>
                                        <DataTrigger TargetType="BoxView" Binding="{Binding Type}" Value="UrlaubGanztag">
                                            <Setter Property="Color" Value="{StaticResource SuccessColor}" />
                                        </DataTrigger>
                                        <DataTrigger TargetType="BoxView" Binding="{Binding Type}" Value="UrlaubHalbtag">
                                            <Setter Property="Color" Value="{StaticResource CyanColor}" />
                                        </DataTrigger>
                                        <DataTrigger TargetType="BoxView" Binding="{Binding Type}" Value="Feiertag">
                                            <Setter Property="Color" Value="{StaticResource Accent}" />
                                        </DataTrigger>
                                    </BoxView.Triggers>
                                </BoxView>

                                <!-- Inhaltsbereich -->
                                <VerticalStackLayout Grid.Column="1" Spacing="2">
                                    <Label Text="{Binding Title}"
                                           FontSize="15"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource TextPrimary}"
                                           LineBreakMode="TailTruncation" />
                                    <Label Text="{Binding TimeRangeDisplay}"
                                           FontSize="12"
                                           TextColor="{StaticResource TextMuted}"
                                           IsVisible="{Binding HasTypeBadge, Converter={StaticResource InverseBoolConverter}}" />
                                    <Border IsVisible="{Binding HasTypeBadge}"
                                            BackgroundColor="{StaticResource SurfaceColor}"
                                            Stroke="Transparent"
                                            StrokeShape="RoundRectangle 6"
                                            Padding="7,2"
                                            HorizontalOptions="Start">
                                        <Label Text="{Binding TypeBadge}"
                                               FontSize="11"
                                               FontAttributes="Bold"
                                               TextColor="{StaticResource TextSecondary}" />
                                    </Border>
                                </VerticalStackLayout>

                                <!-- Rechte Seite: Dauer + Aktionen -->
                                <Grid Grid.Column="2" RowDefinitions="Auto,Auto" ColumnDefinitions="Auto,Auto"
                                      RowSpacing="4" ColumnSpacing="6" VerticalOptions="Center">

                                    <!-- Dauer -->
                                    <Label Grid.Row="0" Grid.ColumnSpan="2"
                                           Text="{Binding DurationDisplay}"
                                           FontSize="13"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource SuccessColor}"
                                           HorizontalOptions="End" />

                                    <!-- Bearbeiten-Button -->
                                    <Border Grid.Row="1" Grid.Column="0"
                                            BackgroundColor="{StaticResource SurfaceColor}"
                                            Stroke="{StaticResource BorderColor}"
                                            StrokeThickness="1"
                                            StrokeShape="RoundRectangle 8">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.EditCommand}"
                                                CommandParameter="{Binding .}" />
                                        </Border.GestureRecognizers>
                                        <Label Text="&#9998;"
                                               FontSize="15"
                                               TextColor="{StaticResource Primary}"
                                               Padding="8,5"
                                               HorizontalOptions="Center" />
                                    </Border>

                                    <!-- Löschen-Button -->
                                    <Border Grid.Row="1" Grid.Column="1"
                                            BackgroundColor="{StaticResource SurfaceColor}"
                                            Stroke="{StaticResource BorderColor}"
                                            StrokeThickness="1"
                                            StrokeShape="RoundRectangle 8">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DeleteCommand}"
                                                CommandParameter="{Binding .}" />
                                        </Border.GestureRecognizers>
                                        <Label Text="&#128465;"
                                               FontSize="15"
                                               TextColor="{StaticResource Accent}"
                                               Padding="8,5"
                                               HorizontalOptions="Center" />
                                    </Border>

                                </Grid>

                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

                <CollectionView.EmptyView>
                    <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="12" Margin="0,60,0,0">
                        <Label Text="📋" FontSize="48" HorizontalOptions="Center" />
                        <Label Text="Noch keine Eintr&#228;ge"
                               FontSize="16"
                               TextColor="{StaticResource TextMuted}"
                               HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>

            </CollectionView>

        </Grid>

        <!-- FAB: Manuellen Eintrag hinzufügen -->
        <Border BackgroundColor="{StaticResource Primary}"
                StrokeShape="RoundRectangle 20"
                Stroke="Transparent"
                WidthRequest="160"
                HeightRequest="50"
                HorizontalOptions="Center"
                VerticalOptions="End"
                Margin="0,0,0,28">
            <Border.Shadow>
                <Shadow Brush="#40000000" Offset="0,4" Radius="12" />
            </Border.Shadow>
            <Border.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding AddManualCommand}" />
            </Border.GestureRecognizers>
            <HorizontalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="8">
                <Label Text="+" FontSize="22" FontAttributes="Bold"
                       TextColor="{StaticResource TextPrimary}" VerticalOptions="Center" />
                <Label Text="Neuer Eintrag" FontSize="15" FontAttributes="Bold"
                       TextColor="{StaticResource TextPrimary}" VerticalOptions="Center" />
            </HorizontalStackLayout>
        </Border>

    </Grid>
</ContentPage>
